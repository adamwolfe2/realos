# ============================================================
# LeaseStack, managed marketing SaaS for real estate operators
# Copy this file to .env.local and fill in all values.
# Never commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------
# Database (Neon)
# ------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_DATABASE_URL="postgresql://user:password@host.region.aws.neon.tech/neondb?sslmode=require"

# ------------------------------------------------------------
# Auth (Clerk)
# Events to subscribe: user.created, user.updated, user.deleted,
#   organization.created, organization.updated, organizationMembership.created
# ------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_..."
CLERK_SECRET_KEY="sk_live_..."
CLERK_WEBHOOK_SECRET="whsec_..."

NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/auth/redirect"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/auth/redirect"

# ------------------------------------------------------------
# Payments (Stripe)
# ------------------------------------------------------------
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ------------------------------------------------------------
# Email (Resend)
# ------------------------------------------------------------
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="LeaseStack <hello@leasestack.co>"

# ------------------------------------------------------------
# SMS (Twilio, optional). When all three are set, the SMS composer
# button appears on /portal/leads/[id] alongside email.
# Use the messaging service SID format for the From number when
# possible (better deliverability + 10DLC compliance).
# ------------------------------------------------------------
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ------------------------------------------------------------
# AI (Anthropic for chatbot, Gemini optional for suggest-reply)
# ------------------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-api03-..."
GEMINI_API_KEY=""

# ------------------------------------------------------------
# Rate Limiting (Upstash KV)
# ------------------------------------------------------------
KV_REST_API_URL="https://your-kv.upstash.io"
KV_REST_API_TOKEN="your-upstash-token"
KV_REST_API_READ_ONLY_TOKEN=""
KV_URL=""
REDIS_URL=""

# ------------------------------------------------------------
# Error Tracking (Sentry)
# ------------------------------------------------------------
SENTRY_AUTH_TOKEN="your-sentry-auth-token"
SENTRY_ORG="your-sentry-org-slug"
SENTRY_PROJECT="your-sentry-project-slug"
NEXT_PUBLIC_SENTRY_DSN=""

# ------------------------------------------------------------
# Cron Job Auth
# ------------------------------------------------------------
CRON_SECRET="your-random-hex-secret"

# ------------------------------------------------------------
# App & Branding
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL="https://leasestack.co"
NEXT_PUBLIC_PLATFORM_DOMAIN="leasestack.co"
ADMIN_EMAIL="ops@leasestack.co"
OPS_NAME="LeaseStack Team"
BRAND_NAME="LeaseStack"
BRAND_LOCATION="San Diego, CA"
NEXT_PUBLIC_BRAND_NAME="LeaseStack"
NEXT_PUBLIC_CONTACT_EMAIL="hello@leasestack.co"
BRAND_PRIMARY_COLOR="#0A0A0A"

# Cal.com namespace + booking link (intake consultation)
NEXT_PUBLIC_CAL_NAMESPACE="leasestack"
NEXT_PUBLIC_CAL_LINK="adamwolfe/leasestack"

# ------------------------------------------------------------
# Agency org seed (singleton)
# ------------------------------------------------------------
AGENCY_ORG_SLUG="leasestack-agency"
AGENCY_ADMIN_EMAIL="adam@leasestack.co"

# ------------------------------------------------------------
# Cursive Pixel (Adam owns)
# ------------------------------------------------------------
CURSIVE_API_KEY="TODO_FILL_IN_CURSIVE_KEY"
CURSIVE_API_URL="https://api.audiencelab.io"
# Shared secret set when creating the AudienceLab SuperPixel. Verified on
# ingress as either the `x-audiencelab-secret` header (shared-secret mode)
# or the HMAC-SHA256 key for `x-audiencelab-signature` (HMAC mode).
CURSIVE_WEBHOOK_SECRET="TODO_FILL_IN_CURSIVE_WEBHOOK_SECRET"

# ------------------------------------------------------------
# Google APIs (platform-level service account)
# Paste the full JSON key file downloaded from GCP → IAM → Service Accounts.
# The service account email must be granted access to each client's GA4 property
# (Viewer role) and GSC site (Full or Restricted permission) individually.
# ------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"leasestack","client_email":"leasestack-integrations@leasestack.iam.gserviceaccount.com","private_key":"..."}'

# ------------------------------------------------------------
# AppFolio
# No platform-level keys are required. Each tenant pastes their own
# Developer Portal clientId / clientSecret in the portal connect drawer
# (HTTP Basic against the Reports API). Tenants without Plus/Max API access
# fall back to embed-scrape mode, which just needs the public subdomain.
# All per-tenant credentials are stored encrypted at rest via ENCRYPTION_KEY.
# ------------------------------------------------------------

# Encryption key for per-tenant AppFolio + ad-account credentials at rest.
# Generate: openssl rand -hex 32
ENCRYPTION_KEY="TODO_FILL_IN_ENCRYPTION_KEY_32_BYTES_HEX"

# ------------------------------------------------------------
# Vercel API (programmatic custom domain attachment for tenant sites)
# ------------------------------------------------------------
VERCEL_API_TOKEN="TODO_FILL_IN_VERCEL_API_TOKEN"
VERCEL_PROJECT_ID="TODO_FILL_IN_VERCEL_PROJECT_ID"
VERCEL_TEAM_ID=""

# ------------------------------------------------------------
# Vercel Blob (file uploads, creative assets)
# ------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=""

# ------------------------------------------------------------
# Analytics (PostHog optional; GA/GTM configured per-tenant)
# ------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# ------------------------------------------------------------
# Slack + Cal.com webhooks (operational)
# ------------------------------------------------------------
# SLACK_WEBHOOK_URL=""
# CAL_WEBHOOK_SECRET=""

# ------------------------------------------------------------
# Bootstrap (one-time admin setup)
# ------------------------------------------------------------
BOOTSTRAP_SECRET="your-random-hex-secret"

# ------------------------------------------------------------
# Weekly report recipients (comma-separated emails)
# ------------------------------------------------------------
REPORT_RECIPIENTS="adam@leasestack.co"

# ------------------------------------------------------------
# Reputation Scanner (per-property "Scan Now" on the Reputation tab)
# Phase 1 uses two sources:
#   - Google Places (New) for native Google Reviews (structured, 5-star)
#   - Tavily for everything else: Reddit threads, Facebook public posts,
#     apartment review aggregators (apartments.com, apartmentratings,
#     niche.com, yelp.com, bbb.org), news, blogs, and general web.
# Both degrade gracefully: if a key is missing, that source shows as
# "failed" in the UI and the other still returns results.
# ------------------------------------------------------------
# Tavily unified web search. Free tier: 1,000 searches/mo. Each scan runs
# 5 parallel queries (Reddit, Facebook, aggregators, review-intent, resident
# context) so 1k/mo = ~200 scans/mo on the free tier.
TAVILY_API_KEY=""

# Google Places API (New). In Google Cloud Console, enable "Places API (New)".
# Each scan resolves or re-reads reviews for one Place ID, cached 24h.
GOOGLE_PLACES_API_KEY=""

# ------------------------------------------------------------
# In-app bug-report button (POST /api/bug-report)
# Fine-grained PAT with `repo` scope on the target repo. The route files an
# Issue with labels `bug`, `in-app-report`, `severity:<low|medium|high|blocker>`.
# ------------------------------------------------------------
GITHUB_TOKEN=""
GITHUB_BUG_REPORT_REPO="adamwolfe2/realos"
# Where bug-report email notifications go. Defaults to ADMIN_EMAIL.
BUG_REPORT_EMAIL=""

# Where ops gets notified when a customer requests a Cursive pixel through
# /portal/settings/integrations. Defaults to ADMIN_EMAIL. AudienceLab does
# not expose a programmatic pixel-creation API, so each request becomes a
# 3-5 minute manual setup task in the AL dashboard.
PIXEL_REQUEST_NOTIFY_EMAIL=""
