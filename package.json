{
  "name": "leasestack",
  "version": "0.1.0",
  "private": true,
  "description": "LeaseStack, managed marketing SaaS for real estate operators",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "vercel-build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:critical": "playwright test --grep @critical",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node --env-file-if-exists=.env.local --import tsx prisma/seed.ts",
    "seed:demo": "node --env-file-if-exists=.env.local --import tsx prisma/seed-demo.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "type-check": "tsc --noEmit",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.47",
    "@clerk/nextjs": "^6.38.2",
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@sentry/nextjs": "^10.40.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.101",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "4.1.0",
    "framer-motion": "^11.18.0",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.564.0",
    "next": "^16.1.6",
    "posthog-js": "^1.360.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "2.15.0",
    "resend": "^6.9.2",
    "simple-icons": "^16.17.0",
    "sonner": "^1.7.1",
    "stripe": "^20.3.1",
    "svix": "^1.85.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.3.1",
    "glob": "^13.0.6",
    "postcss": "^8.5",
    "prisma": "^7.4.1",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/engines",
      "@prisma/client",
      "esbuild",
      "sharp",
      "@clerk/shared"
    ]
  }
}
