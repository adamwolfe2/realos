  serpPosition Int? // live SERP position from DataforSEO
  serpFeatures String[] @default([])

  // GSC
  gscImpressions Int    @default(0)
  gscClicks      Int    @default(0)
  gscCtr         Float? // 0..1
  gscPosition    Float? // GSC-reported average position

  // GA4
  ga4Sessions         Int    @default(0)
  ga4Users            Int    @default(0)
  ga4EngagedSessions  Int    @default(0)
  ga4AvgEngagementSec Float?
  ga4Conversions      Int    @default(0)
