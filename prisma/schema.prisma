// ============================================================================
// PAID ADS
// ============================================================================

model AdAccount {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  platform          AdPlatform
  externalAccountId String // Google Ads customer ID (10-digit, no dashes); Meta ad account ID (numeric, no act_ prefix)
  displayName       String? // Operator-chosen label, e.g. "Telegraph Commons - Search"
  currency          String?    @default("USD") // ISO 4217. Reported by both APIs.

  accessStatus String? @default("active") // active, expired, revoked, error

  // Encrypted credential bag (stringified JSON). Schema differs per platform:
  //   Google Ads: { developerToken, loginCustomerId?, refreshToken, oauthClientId, oauthClientSecret }
  //   Meta Ads:   { systemUserAccessToken }
  // The integration lib decrypts and parses on use. Keeping it as a single
  // blob lets us avoid a second migration when we add OAuth-issued tokens.
  credentialsEncrypted String? @db.Text

  // Legacy/OAuth fields kept so we can migrate to OAuth later without a
  // schema change. Not used by the V1 paste-in-credentials flow.
  tokenEncrypted        String?   @db.Text
  refreshTokenEncrypted String?   @db.Text
  tokenExpiresAt        DateTime?

  pixelSyncEnabled Boolean   @default(false)
  autoSyncEnabled  Boolean   @default(true)
  lastSyncAt       DateTime?
  lastSyncError    String?   @db.Text

  adCampaigns          AdCampaign[]
  metricsDaily         AdMetricDaily[]
  audienceDestinations AudienceDestination[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, platform, externalAccountId])
  @@index([orgId, platform])
}

model AdCampaign {
  id          String       @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  propertyId  String?
  property    Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  adAccountId String
  adAccount   AdAccount    @relation(fields: [adAccountId], references: [id], onDelete: Cascade)

  externalCampaignId String?
  name               String
  platform           AdPlatform
  status             String? // ENABLED/PAUSED/REMOVED (Google), ACTIVE/PAUSED/DELETED (Meta)
  objective          String? // Meta: OUTCOME_LEADS / OUTCOME_TRAFFIC / ...; Google: SEARCH/PMAX/DISPLAY/...

  // Budget
  dailyBudgetCents   Int?
  monthlyBudgetCents Int?
  spendToDateCents   Int?      @default(0)
  startDate          DateTime?
  endDate            DateTime?

  // Performance (denormalized, refreshed via cron from AdMetricDaily)
  impressions Int?      @default(0)
  clicks      Int?      @default(0)
  conversions Int?      @default(0)
  lastStatsAt DateTime?

  startedAt DateTime?
  endedAt   DateTime?

  metricsDaily AdMetricDaily[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([adAccountId, externalCampaignId])
  @@index([orgId, status])
  @@index([adAccountId])
}

// Per-campaign per-day metrics. One row per (campaignId, date) so the cron
// can upsert idempotently. The dashboard reads this for time-series + 28-day
// aggregates; AdCampaign holds the rolling totals as a denorm.
model AdMetricDaily {
  id          String     @id @default(cuid())
  orgId       String
  adAccountId String
  adAccount   AdAccount  @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  campaignId  String
  campaign    AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  date                   DateTime @db.Date // UTC midnight of the metric day
  impressions            Int      @default(0)
  clicks                 Int      @default(0)
  spendCents             Int      @default(0)
  conversions            Float    @default(0) // Meta returns fractional conversions
  conversionValueCents   Int      @default(0)
  ctr                    Float    @default(0) // clicks / impressions, 0..1
  cpcCents               Int      @default(0) // spend / clicks
  costPerConversionCents Int      @default(0) // spend / conversions

  raw Json? // Raw payload from the platform for debugging

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, date])
  @@index([orgId, date])
  @@index([adAccountId, date])
  // Campaigns page rolls daily metrics up by campaignId; the existing
  // unique handles point lookups but the date-DESC ordering needs an
  // explicit index to avoid sorting at query time.
  @@index([campaignId, date(sort: Desc)])
}

// ============================================================================
// BACKEND INTEGRATIONS
// ============================================================================

model AppFolioIntegration {
  id    String       @id @default(cuid())
  orgId String       @unique
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  instanceSubdomain     String // e.g., sgrealestate (from sgrealestate.appfolio.com)
  plan                  String? // "plus", "max", "core"
  apiKeyEncrypted       String?   @db.Text
  clientIdEncrypted     String?   @db.Text
  clientSecretEncrypted String?   @db.Text
  oauthTokenEncrypted   String?   @db.Text
  oauthRefreshEncrypted String?   @db.Text
  oauthExpiresAt        DateTime?

  // Sync state
  lastSyncAt    DateTime?
  // When the current "syncing" run actually started. Persisted so the UI
  // can show real elapsed time across page navigations (a per-component
  // local counter resets on every mount and reads as a "sync restart"
  // even when the underlying sync is still running). Cleared on
  // completion. Used by the status helper to mark stuck syncs (older
  // than 10 min) as failed instead of letting them sit forever.
  syncStartedAt DateTime?
  syncStatus    String? // idle, syncing, error
  lastError     String?
  // Detailed stats from the most recent sync run. Persisted so the UI can
  // surface "X residents · Y leases · Z work orders pulled" + per-phase
  // warnings even when the sync technically succeeded but a sub-endpoint
  // (e.g. residents) silently returned 0 rows or 403'd. Shape matches
  // AppfolioSyncStats in lib/integrations/appfolio-sync.ts.
  lastSyncStats Json?

  // Configuration
  propertyGroupFilter  String? // Only sync specific property groups
  syncFrequencyMinutes Int     @default(60)
  autoSyncEnabled      Boolean @default(true)

  // Fallback mode
  useEmbedFallback  Boolean @default(false)
  embedScriptConfig Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// KEPT FROM WHOLESAIL (SURVIVE AS-IS OR LIGHTLY EXTENDED)
// ============================================================================

model Address {
  id         String       @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  label      String?
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String       @default("US")
  isDefault  Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([orgId])
}

model AuditEvent {
  id     String       @id @default(cuid())
  orgId  String
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId String?
  user   User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  action      AuditAction
  entityType  String // "Lead", "Property", etc.
  entityId    String?
  description String?
  diff        Json?
  ipAddress   String?
  userAgent   String?

  createdAt DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([entityType, entityId])
}

model WebhookEvent {
  id               String   @id @default(cuid())
  source           String // "cursive", "appfolio", "stripe"
  bodyHash         String? // SHA-256 of raw POST body, hex. Catches byte-identical AL retries.
  eventFingerprint String? // sha256(pixel_id|profile_id|event_timestamp|event_type). Catches re-serialized duplicates within a batch.
  eventType        String?
  orgId            String?
  receivedAt       DateTime @default(now())

  // Retry queue tracking — webhook-retry cron picks up status=failed events
  // whose nextRetryAt is in the past.
  status          String    @default("received") // received | processed | failed | abandoned
  attempts        Int       @default(0)
  lastAttemptAt   DateTime?
  processingError String?   @db.Text
  rawBody         String?   @db.Text // Stored only when processing fails so retries can replay
  nextRetryAt     DateTime?

  @@unique([source, bodyHash])
  @@unique([source, eventFingerprint])
  @@index([source, receivedAt])
  @@index([status, nextRetryAt])
}

// Per-tenant request to activate an integration that isn't self-serve yet.
// The portal marketplace drawer writes one of these when the operator clicks
// "Request activation" on a tile whose auth flow isn't built yet. Surfaces
// in the admin queue so we know what to prioritize building.
model IntegrationRequest {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  integrationSlug  String // matches lib/integrations/catalog.ts slug
  status           IntegrationRequestStatus @default(PENDING)
  message          String?                  @db.Text
  requestedByEmail String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  @@index([orgId, status])
  @@index([integrationSlug, status])
}

enum IntegrationRequestStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  REJECTED
}

// ============================================================================
// SEO MODULE
// ----------------------------------------------------------------------------
// Pulls organic search performance data from two providers per tenant:
//   - GSC  → Google Search Console (queries, impressions, clicks, position)
//   - GA4  → Google Analytics Data API (organic sessions, users, engagement,
//            top landing pages)
//
// Both authenticate via a service account JSON pasted by the operator. The
// service account email must be granted access to the GSC site / GA4 property
// before connecting. JSON is encrypted at rest using lib/crypto.ts.
//
// Snapshots are written daily by /api/cron/seo-sync. Schema is normalized so
// trends across weeks/months can be queried cheaply with date range filters.
// ============================================================================

enum SeoProvider {
  GSC
  GA4
}

enum SeoSyncStatus {
  IDLE
  SYNCING
  ERROR
}

model SeoIntegration {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Per-property scoping. NULL = legacy "applies to whole org" — every
  // existing SeoIntegration row at the time of the multi-property
  // migration is NULL, which preserves the prior single-GA4 / single-
  // GSC-per-org behavior. New connections always specify a property so
  // multi-property tenants can run a distinct GA4 property + GSC site
  // per LeaseStack property.
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  provider                    SeoProvider
  // GSC: full site URL, e.g. "sc-domain:telegraphcommons.com" or
  //      "https://www.telegraphcommons.com/". GA4: property id, e.g. "123456789".
  // (Note: this is the GA4/GSC-side identifier, NOT the LeaseStack
  // Property.id — those are separate concerns linked via `propertyId`
  // above.)
  propertyIdentifier          String
  serviceAccountEmail         String? // surfaced in UI so operators know which email to grant access to
  serviceAccountJsonEncrypted String      @db.Text // encrypted full JSON payload

  status        SeoSyncStatus @default(IDLE)
  lastSyncAt    DateTime?
  lastSyncError String?       @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Composite unique: one row per (org, property, provider). The
  // legacy "all properties" row is keyed (orgId, NULL, provider) and
  // coexists with per-property rows because Postgres treats NULL as
  // distinct in unique indexes.
  @@unique([orgId, propertyId, provider])
  @@index([orgId])
  @@index([propertyId])
}

// Daily aggregate per tenant. Re-run-safe via the unique (orgId, date) index.
model SeoSnapshot {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  date             DateTime // start of the calendar day in UTC
  organicSessions  Int      @default(0)
  organicUsers     Int      @default(0)
  totalImpressions Int      @default(0)
  totalClicks      Int      @default(0)
  avgCtr           Float    @default(0) // 0 to 1
  avgPosition      Float    @default(0) // GSC search position, lower is better

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, date])
  @@index([orgId, date])
}

// One row per (tenant, date, query). Drives the "top queries" table.
model SeoQuery {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  date        DateTime
  query       String   @db.Text
  impressions Int      @default(0)
  clicks      Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)

  createdAt DateTime @default(now())

  @@unique([orgId, date, query])
  @@index([orgId, date])
  @@index([orgId, clicks])
}

// One row per (tenant, date, url). Drives the "top landing pages" table.
model SeoLandingPage {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  date              DateTime
  url               String   @db.Text
  sessions          Int      @default(0)
  users             Int      @default(0)
  bounceRate        Float    @default(0)
  avgEngagementTime Float    @default(0) // seconds

  createdAt DateTime @default(now())

  @@unique([orgId, date, url])
  @@index([orgId, date])
  @@index([orgId, sessions])
}

model ClientNote {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  authorUserId String?
  noteType     NoteType @default(GENERAL)
  body         String   @db.Text
  pinned       Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, createdAt])
}

model IntakeSubmission {
  id    String        @id @default(cuid())
  orgId String?       @unique // Null until org created
  org   Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  // Step 1: Company
  companyName         String
  shortName           String?
  websiteUrl          String?
  propertyType        PropertyType
  residentialSubtype  ResidentialSubtype?
  commercialSubtype   CommercialSubtype?
  primaryContactName  String
  primaryContactEmail String
  primaryContactPhone String?
  primaryContactRole  String?
  hqCity              String?
  hqState             String?

  // Step 2: Portfolio
  numberOfProperties       Int?
  currentBackendPlatform   BackendPlatform @default(NONE)
  backendPlanTier          String?
  currentVendor            String?
  currentMonthlySpendCents Int?
  biggestPainPoint         String?

  // Step 3: Service selection (module toggles)
  selectedModules Json // Array of module keys

  // Step 4: Timeline + consultation
  goLiveTarget String? // asap, 1_month, 3_month, exploring
  bookedCallAt DateTime?
  calBookingId String?

  // Submission metadata
  status      String    @default("submitted") // submitted, in_review, converted, rejected
  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?
  convertedAt DateTime?

  ipAddress   String?
  userAgent   String?
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  raw Json? // Full form payload for audit
}

model Project {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  name        String // e.g., "Telegraph Commons Build"
  description String?
  status      String  @default("active") // active, on_hold, completed, cancelled

  startedAt          DateTime?
  targetCompletionAt DateTime?
  completedAt        DateTime?

  tasks ProjectTask[]
  costs ProjectCost[]
  notes ProjectNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, status])
}

// Tracks paid custom-website-build requests. NOT part of the trial:
// the customer pays via Stripe Checkout up front, books a kickoff
// call on Cal.com, and Adam (or whoever is fulfilling) drives the
// build inside /admin/website-builds.
//
// Status lifecycle:
//   requested  - paid; awaiting kickoff call booking
//   scoping    - kickoff call booked; gathering assets + brief
//   designing  - in design
//   building   - implementation underway
//   review     - first review with customer pending
//   live       - launched to their domain
//   cancelled  - refund issued (or "decided to bring own site")
model WebsiteBuildRequest {
  id         String       @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  propertyId String?
  property   Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  // Stripe references for the payment that kicked this off. We store
  // the session id (not just the customer/invoice) so we can replay
  // the original quote during fulfillment without re-deriving it.
  stripeCheckoutSessionId String? @unique
  stripeInvoiceId         String?
  stripePaymentIntentId   String?
  amountPaidCents         Int     @default(0)

  // Cal.com booking metadata. We capture the booking URL on payment
  // success (so the success page can deep-link) and the timestamp
  // once the booking webhook fires (if we wire one).
  calBookingUrl String?
  calBookedAt   DateTime?
  kickoffCallAt DateTime?

  status String @default("requested")

  // Free-form intake we capture at checkout time (preferred site
  // style, references, existing domain). Stored as JSON so we can
  // evolve the shape without migrations.
  intakeJson Json?

  // Admin-side fulfillment metadata.
  assignedToUserId   String?
  assignedTo         User?     @relation("WebsiteBuildAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  launchedAt         DateTime?
  cancelledAt        DateTime?
  cancellationReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, status])
  @@index([assignedToUserId, status])
}

// ============================================================================
// Site Engine — public + portal-based intake for custom marketing site builds.
// Sits ALONGSIDE WebsiteBuildRequest (which is a Stripe-paid kickoff queue).
// SiteRequest is the richer intake record: a state-machine row created by the
// public form at /sites/request OR the logged-in form at /portal/sites/request.
// Adam (or a contractor) works the queue at /admin/site-engine, downloads a
// build packet (intake.json + assets zip), and builds the site by hand in
// Claude Code. Every client site is its own GitHub repo + Vercel project; this
// model just tracks the intake/queue/lifecycle inside LeaseStack.
// ============================================================================

enum SiteRequestStatus {
  SUBMITTED                  // Just landed; not yet triaged.
  TRIAGE                     // Adam reviewing fit + completeness.
  NEEDS_INFO                 // Awaiting missing info from client.
  DISQUALIFIED               // Politely declined.
  QUALIFIED                  // Ready to begin build prep.
  INSPIRATION_EXTRACTION     // Reverse-PRD pass on inspiration URLs.
  SPEC_REVIEW                // Merged spec ready for Adam approval.
  READY_TO_BUILD             // Spec approved; build packet downloadable.
  IN_BUILD                   // Active Claude Code session.
  PREVIEW_READY              // Preview URL generated.
  CLIENT_REVIEW              // Client reviewing the preview.
  REVISION_REQUESTED         // Client asked for changes.
  APPROVED                   // Client signed off.
  DEPLOYED                   // Live on production domain.
  MAINTENANCE                // Post-launch ongoing.
  PAUSED                     // Something blocked; manual intervention.
  CHURNED                    // Client left.
}

enum SiteRequestTier {
  TIER1_MARKETING  // Single marketing site
  TIER2_PORTAL     // Marketing + lead capture + tenant portal stub
  TIER3_CUSTOM     // Full custom scope
}

enum SiteRequestPriority {
  URGENT
  NORMAL
  LOW
}

enum SiteRequestAssetType {
  LOGO
  HERO
  HEADSHOT
  PROPERTY_PHOTO
  LISTING_PHOTO
  BRAND_GUIDE
  INSPIRATION
  OTHER
}

model SiteRequest {
  id   String @id @default(cuid())
  slug String @unique // Short shareable URL token (used in /sites/status/[slug]).

  // Linkage to existing LeaseStack org. NULL when submitted by a public
  // visitor with no LeaseStack account yet (magic link flow can claim it
  // later by setting orgId).
  orgId String?
  org   Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  // Submitter snapshot (always populated, even for logged-in submissions —
  // we keep an immutable copy of who actually filled the form).
  submittedByName    String
  submittedByEmail   String
  submittedByPhone   String?
  submittedByCompany String?

  // Lifecycle
  status            SiteRequestStatus   @default(SUBMITTED)
  tier              SiteRequestTier     @default(TIER1_MARKETING)
  priority          SiteRequestPriority @default(NORMAL)
  estimatedLaunchAt DateTime?

  // Attribution. `source` is the referrer slug from ?ref= (e.g. "norman"),
  // utm_* preserved for analytics.
  source      String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  referrer    String?
  ipAddress   String?
  userAgent   String?

  // Fulfillment metadata
  assignedToUserId String?
  assignedTo       User?       @relation("SiteRequestAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  internalNotes    String?     @db.Text

  // Build artifact references — populated as the build progresses.
  githubRepoUrl     String?
  vercelProjectId   String?
  vercelPreviewUrl  String?
  productionUrl     String?
  previewSentAt     DateTime?
  approvedAt        DateTime?
  deployedAt        DateTime?
  disqualifiedAt    DateTime?
  disqualifiedReason String?

  // 1:1 form payload + related collections.
  intake     IntakeResponse?
  assets     SiteRequestAsset[]
  events     SiteRequestEvent[]

  submittedAt    DateTime  @default(now())
  lastActivityAt DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status, lastActivityAt])
  @@index([orgId, status])
  @@index([assignedToUserId, status])
  @@index([source])
}

// 1:1 with SiteRequest. Stored separately so we can evolve the intake
// shape without bloating the queue index. Free-form `raw` blob keeps the
// entire original submission for audit.
model IntakeResponse {
  id            String      @id @default(cuid())
  siteRequestId String      @unique
  siteRequest   SiteRequest @relation(fields: [siteRequestId], references: [id], onDelete: Cascade)

  // Identity
  identityType String? // solo_agent | team | brokerage | property_manager | developer | other

  // Brand
  brandName       String
  tagline         String?
  brandColorHex   String?
  vertical        String? // residential | commercial | mixed | senior_living | etc.

  // Compliance
  licenseNumber String?
  brokerageName String?
  licenseState  String?

  // Service area
  serviceAreas String[] @default([])
  hqCity       String?
  hqState      String?

  // Existing presence
  currentSiteUrl String?
  domain         String?
  domainNeeded   Boolean? // true = they need us to register
  dnsAccess      Boolean? // true = they have registrar access

  // Visual direction (legacy single-pick fields — kept for back-compat).
  inspirationUrls String[] @default([])
  presetChoice    String? // editorial_luxury | cinematic_portfolio | etc.

  // Multi-modal visual direction (new in May 2026). Either or all of these
  // can be set per submission. The build packet endpoint denormalizes them
  // into the zip (chosen design language full MD + chosen palette full JSON).
  chosenPresetSlug         String? // site-engine-kit preset slug
  chosenDesignLanguageSlug String? // site-engine-kit/design-languages slug
  chosenPaletteSlug        String? // site-engine-kit/palettes slug
  negativeInputs           String? @db.Text // "I don't want anything that..."

  // Voice & content
  voiceSample  String? @db.Text // 200+ word writing sample
  bio          String? @db.Text
  services     Json? // array of { title, description }
  testimonials Json? // array of { name, quote, role }
  keyStats     Json? // array of { label, value }

  // Integrations
  calendlyUrl   String?
  crmChoice     String?
  mlsPreference String?
  ga4Id         String?

  // Timeline + budget
  timelineExpectation String? // asap | 1_month | 3_month | flexible
  budgetConfirmed     Boolean?
  budgetTier          String?

  // Open text
  anythingElse String? @db.Text

  // Full raw payload (every form field, even ones not modeled above) for audit.
  raw Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Uploaded files (logos, photos, brand guides, inspiration shots).
model SiteRequestAsset {
  id            String      @id @default(cuid())
  siteRequestId String
  siteRequest   SiteRequest @relation(fields: [siteRequestId], references: [id], onDelete: Cascade)

  type     SiteRequestAssetType
  filename String
  mimeType String
  size     Int
  blobUrl  String
  pathname String?
  label    String? // optional caption supplied by the submitter

  uploadedAt DateTime @default(now())

  @@index([siteRequestId, type])
}

// Append-only audit trail of status transitions and key actions on a
// SiteRequest. Drives the timeline shown on /admin/site-engine/[id] and
// on the client status page.
model SiteRequestEvent {
  id            String      @id @default(cuid())
  siteRequestId String
  siteRequest   SiteRequest @relation(fields: [siteRequestId], references: [id], onDelete: Cascade)

  kind         String // status_change | note | email_sent | preview_sent | revision_requested | packet_downloaded
  fromStatus   SiteRequestStatus?
  toStatus     SiteRequestStatus?
  message      String? @db.Text
  actorUserId  String? // null for system / public submitter events
  visibleToClient Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([siteRequestId, createdAt])
}

model ProjectTask {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title            String
  description      String?
  status           TaskStatus @default(TODO)
  assignedToUserId String?
  assignedTo       User?      @relation("TaskAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  phase       String? // "Build", "QA", "Launch", etc.
  sortOrder   Int       @default(0)
  dueAt       DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, status])
}

model ProjectCost {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  label       String
  amountCents Int
  category    String? // infrastructure, api_cost, ad_spend, etc.
  incurredAt  DateTime @default(now())

  createdAt DateTime @default(now())

  @@index([projectId])
}

model ProjectNote {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  authorUserId String?
  body         String  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model EmailSubscriber {
  id    String        @id @default(cuid())
  orgId String? // Null = platform-level subscriber
  org   Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  email     String
  firstName String?
  source    String? // lead_magnet, footer, blog, etc.
  tags      Json?

  confirmed      Boolean   @default(false)
  confirmedAt    DateTime?
  unsubscribed   Boolean   @default(false)
  unsubscribedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, email])
  @@index([orgId])
}

// ============================================================================
// SYSTEM HEALTH
// ----------------------------------------------------------------------------
// One row per cron handler invocation. Written by lib/health/cron-run.ts at
// start (status=running) and updated on finish (ok/error/timeout). The
// /admin/system dashboard reads the most recent row per jobName so an
// operator can see at a glance which crons fired in the last 24 hours and
// which are silently dead. Migration lives in
// prisma/migrations_pending/2026-04-20-cron-runs.sql (Adam applies).
// ============================================================================

model CronRun {
  id               String    @id @default(cuid())
  jobName          String
  startedAt        DateTime  @default(now())
  finishedAt       DateTime?
  status           String    @default("running") // running | ok | error | timeout
  error            String?   @db.Text
  durationMs       Int?
  recordsProcessed Int?

  createdAt DateTime @default(now())

  @@index([jobName, startedAt])
  @@index([startedAt])
  @@index([status])
}

// ============================================================================
// NOTIFICATIONS
// ----------------------------------------------------------------------------
// In-app notification inbox for operators. Rows are created by server helpers
// when interesting events occur (new lead, tour scheduled, chatbot lead, etc.).
// The portal header bell polls /api/portal/notifications/unread-count every
// 30 s and the /portal/notifications page lists all rows for the org.
// ============================================================================

model Notification {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Optional: target a specific user. Null = org-wide (visible to all members).
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Event classification
  kind String // lead_created | tour_scheduled | chatbot_lead | integration_error | sync_complete

  // Display
  title String
  body  String? @db.Text

  // Optional link back to the source entity
  entityType String?
  entityId   String?
  href       String? // /portal/leads/<id> etc.

  // Read state
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([orgId, readAt])
  @@index([orgId, createdAt(sort: Desc)])
  @@index([orgId, kind])
}

// ============================================================================
// INSIGHTS
// ----------------------------------------------------------------------------
// Proactively detected anomalies and opportunities. A background cron
// (insight-detector) runs scheduled checks per org and upserts Insight rows
// via dedupeKey so the same anomaly doesn't fire repeatedly. Operators view
// them on /portal/insights and in the Command Center briefing.
// ============================================================================

model Insight {
  id         String       @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  propertyId String?
  property   Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  // Classification
  kind     String // traffic_drop | traffic_spike | pipeline_stall | chatbot_pattern | cpl_spike | keyword_drop | conv_rate_drop | hot_visitor
  severity String @default("info") // info | warning | critical
  category String // traffic | leads | ads | seo | chatbot | occupancy

  title           String
  body            String  @db.Text
  suggestedAction String? @db.Text

  // Optional link back to the source entity
  entityType String? // lead | property | campaign | conversation | visitor
  entityId   String?
  href       String? // /portal/... deep link

  // Metric context for rendering (JSON):
  // { before, after, deltaPct, periodStart, periodEnd, sampleSize, ... }
  context Json?

  // Operator workflow
  status         String    @default("open") // open | acknowledged | dismissed | acted
  acknowledgedAt DateTime?
  acknowledgedBy String? // userId
  dismissedAt    DateTime?
  snoozeUntil    DateTime?

  // Dedupe so the same anomaly doesn't fire repeatedly. Detectors compose
  // stable keys like "traffic_drop:propertyId:week:2026-16".
  dedupeKey String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, dedupeKey])
  @@index([orgId, status, severity])
  @@index([orgId, createdAt(sort: Desc)])
  @@index([orgId, category, status])
  @@index([propertyId])
}

// ============================================================================
// CLIENT REPORTS
// ----------------------------------------------------------------------------
// Operator-generated weekly and monthly client reports. snapshot is frozen at
// generation time so viewing the report later shows the exact numbers the
// operator sent. shareToken powers /r/[token] public viewer. Operator writes
// a personal note (headline + notes) before sharing.
// ============================================================================

model ClientReport {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Optional property scope. When set, the snapshot's queries were filtered
  // to this property only — useful for multi-property tenants who want a
  // per-asset client report instead of a portfolio-wide rollup. NULL means
  // org-wide (the original behavior). SetNull on delete so historical
  // reports survive a property removal with the scope context dropped.
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  kind        String // weekly | monthly | custom
  periodStart DateTime
  periodEnd   DateTime

  // Frozen data snapshot used for rendering the report.
  // Shape: { kpis, funnel, leadSources, topProperties, insights, trafficTrend, ... }
  snapshot Json

  // Operator additions shown at top of report
  headline String?
  notes    String? @db.Text

  // Sharing
  shareToken   String    @unique // short URL token for /r/[token]
  sharedAt     DateTime?
  lastViewedAt DateTime?
  viewCount    Int       @default(0)

  status String @default("draft") // draft | shared | archived

  generatedAt DateTime @default(now())
  generatedBy String? // userId (no FK — rows outlive user deletes)
  updatedAt   DateTime @updatedAt

  @@index([orgId, kind, periodStart(sort: Desc)])
  @@index([orgId, status, generatedAt(sort: Desc)])
  @@index([orgId, propertyId, generatedAt(sort: Desc)])
  @@index([shareToken])
}

// ============================================================================
// CONVERSATION FLAGS
// ----------------------------------------------------------------------------
// Operator annotations on chatbot conversations. Used in the transcript review
// tool to mark quality, flag for prompt tuning, rate lead quality, add notes.
// Multiple flags per conversation are allowed (e.g. "good quality" + "needs
// followup" + "high-intent lead").
// ============================================================================

model ConversationFlag {
  id             String              @id @default(cuid())
  conversationId String
  conversation   ChatbotConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  orgId          String
  org            Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Flag type
  flag String // quality_good | quality_bad | needs_prompt_tuning | lead_high_intent | lead_low_intent | followup_needed | handoff_missed
  note String? @db.Text

  createdByUserId String?
  createdAt       DateTime @default(now())

  @@index([orgId, flag])
  @@index([conversationId])
  @@index([orgId, createdAt(sort: Desc)])
}

// ============================================================================
// REPUTATION SCANNER
// ----------------------------------------------------------------------------
// On-demand reputation & intent-signal scanner. A customer clicks "Scan Now"
// on a Property; the API route fans out to Google Places, Tavily, Reddit, and
// Yelp, dedupes by URL hash, classifies sentiment/topics via Claude Haiku,
// and persists results here. ReputationScan captures the run metadata;
// PropertyMention captures each individual mention (one row per unique
// URL per property per org).
// ============================================================================

enum ReputationScanStatus {
  RUNNING
  SUCCEEDED
  PARTIAL // at least one source failed but others returned data
  FAILED
}

enum MentionSource {
  GOOGLE_REVIEW
  REDDIT
  YELP
  TAVILY_WEB
  FACEBOOK_PUBLIC
  OTHER
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
  MIXED
}

model ReputationScan {
  id         String       @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  triggeredByUserId String? // internal User.id, not Clerk id
  status            ReputationScanStatus @default(RUNNING)

  // Per-source result summary: { google: { found, newCount, ok, error? }, ... }
  sources Json?

  newMentionCount   Int     @default(0)
  totalMentionCount Int     @default(0)
  estCostCents      Int     @default(0)
  durationMs        Int?
  error             String?

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  mentions PropertyMention[]

  @@index([orgId, propertyId, createdAt(sort: Desc)])
  @@index([orgId, status])
}

model PropertyMention {
  id         String       @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  source    MentionSource
  sourceUrl String // canonical URL
  urlHash   String // sha256 of normalized URL, used for dedupe

  title       String?
  excerpt     String    @db.Text
  authorName  String?
  publishedAt DateTime?
  rating      Float? // 1-5 when available (Google, Yelp)

  sentiment           Sentiment?
  sentimentConfidence Float? // 0..1, populated by Claude in lib/reputation/analyze.ts
  topics              Json? // Array of strings, e.g. ["maintenance", "noise"]. Surfaced as "themes" in the UI.

  reviewedByUserId String?
  flagged          Boolean @default(false)

  firstSeenScanId String
  firstSeenScan   ReputationScan @relation(fields: [firstSeenScanId], references: [id], onDelete: Cascade)
  lastSeenAt      DateTime       @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, propertyId, urlHash])
  @@index([orgId, propertyId, publishedAt(sort: Desc)])
  @@index([orgId, propertyId, sentiment])
  @@index([firstSeenScanId])
}

// ============================================================================
// AUDIENCE SYNC — residential/commercial product line
// ============================================================================
// AudienceSegment caches AudienceLab segments visible to an org. Cache is
// refreshed on dashboard load or via a manual "Refresh" action. We don't
// persist members here; members are fetched on-demand at push time.

enum AudienceDestinationType {
  CSV_DOWNLOAD
  WEBHOOK
  META_CUSTOM_AUDIENCE
  GOOGLE_CUSTOMER_MATCH
}

enum AudienceSyncStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model AudienceSegment {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // AudienceLab segment id (their primary key, opaque string)
  alSegmentId String
  name        String
  description String?

  // Last known member count from AL. Refreshed on list pulls.
  memberCount Int @default(0)

  // Stash the raw AL payload for the segment so we can render attribute
  // chips without a second round-trip. Updated on every refresh.
  rawPayload Json?

  // Whether this org chooses to surface the segment in their dashboard.
  // Defaults to true on import; toggled off if user hides it.
  visible Boolean @default(true)

  lastFetchedAt DateTime?

  destinations AudienceDestination[]
  syncRuns     AudienceSyncRun[]
  schedules    AudienceSyncSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, alSegmentId])
  @@index([orgId, visible])
}

model AudienceDestination {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  type AudienceDestinationType
  name String // operator-friendly label

  // For WEBHOOK: target URL + signing secret. Stored encrypted (AES-GCM)
  // via the same maybeDecrypt helper used for ad creds.
  webhookUrl       String?
  webhookSecretEnc String?

  // For META_CUSTOM_AUDIENCE / GOOGLE_CUSTOMER_MATCH: pointer to the
  // already-connected AdAccount. Reuses existing OAuth credentials.
  adAccountId String?
  adAccount   AdAccount? @relation(fields: [adAccountId], references: [id], onDelete: SetNull)

  // External audience id on the destination platform (Meta CA id, Google
  // user list resource name). Created lazily on first push.
  externalAudienceId String?

  // Optional segment binding. When set, this destination is "default" for
  // the segment and shows on its detail page. Null means "shared/global"
  // across all segments in the org.
  segmentId String?
  segment   AudienceSegment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)

  enabled    Boolean   @default(true)
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  syncRuns  AudienceSyncRun[]
  schedules AudienceSyncSchedule[]

  @@index([orgId, type])
  @@index([segmentId])
  @@index([adAccountId])
}

model AudienceSyncRun {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  segmentId     String
  segment       AudienceSegment     @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  destinationId String
  destination   AudienceDestination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  status      AudienceSyncStatus @default(PENDING)
  memberCount Int                @default(0)

  // Geo filter snapshot at run time (zip codes, state, radius). Null if
  // no filter was applied.
  filterSnapshot Json?

  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  errorMessage String?

  // Triggered by user (userId) or system cron (null).
  triggeredByUserId String?

  @@index([orgId, startedAt(sort: Desc)])
  @@index([segmentId, startedAt(sort: Desc)])
  @@index([destinationId, startedAt(sort: Desc)])
  @@index([status])
}

// AudienceSyncSchedule defines a recurring push of a segment to a destination.
// The cron at /api/cron/run-audience-syncs picks rows where enabled=true and
// nextRunAt <= now() each tick, executes the push, then advances nextRunAt to
// the next due time based on frequency.
enum AudienceScheduleFrequency {
  DAILY
  WEEKLY
}

model AudienceSyncSchedule {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  segmentId     String
  segment       AudienceSegment     @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  destinationId String
  destination   AudienceDestination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  frequency AudienceScheduleFrequency
  // 0-6 (Sunday=0). Required when frequency = WEEKLY, ignored when DAILY.
  dayOfWeek Int?
  // 0-23, the hour of the day (UTC) the run kicks off.
  hourUtc   Int

  // Optional GeoFilter snapshot { zipCodes?: string[]; states?: string[]; cities?: string[] }
  filterSnapshot Json?

  enabled   Boolean   @default(true)
  lastRunAt DateTime?
  nextRunAt DateTime

  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([orgId, enabled])
  @@index([nextRunAt, enabled])
  @@index([segmentId])
  @@index([destinationId])
}

// ============================================================================
// AD LIBRARY TRACKING
// ============================================================================
//
// Snapshots of public ads found in Meta's Ad Library for any advertiser the
// operator wants to track. Pulled via the public Ad Library API at
// graph.facebook.com/v19.0/ads_archive (requires a Meta app access token,
// not customer credentials — agency holds one app token). Refreshed daily
// by cron; diffs against prior snapshots so the operator sees "3 ads
// launched this week, 1 went inactive".
//
// Importantly: Meta only exposes impressions/spend RANGES for political /
// issue / social ads. Commercial ads return creative + status + dates only.
// We surface what's available; the schema is permissive.

model AdLibraryAdvertiser {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Optional property scope — when set, the widget renders on the
  // property detail page; when null, it's an org-wide tracker.
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  // What we feed Meta's Ad Library search. Either a Page ID or a search
  // term (the operator can paste either).
  searchKind  AdLibrarySearchKind
  searchValue String

  // Friendly label displayed in the UI (e.g. "Telegraph Commons").
  displayName String

  lastScannedAt DateTime?
  lastScanError String?

  ads AdLibraryAd[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, searchValue])
  @@index([orgId])
  @@index([propertyId])
}

enum AdLibrarySearchKind {
  PAGE_ID
  SEARCH_TERM
}

model AdLibraryAd {
  id           String              @id @default(cuid())
  advertiserId String
  advertiser   AdLibraryAdvertiser @relation(fields: [advertiserId], references: [id], onDelete: Cascade)

  // Meta's library ID for this ad. Unique per advertiser.
  externalId String

  // Status from Meta — ACTIVE / INACTIVE.
  status String

  // Creative content (any field may be null depending on ad type).
  creativeBody  String? @db.Text
  creativeTitle String? @db.Text
  ctaText       String?
  imageUrl      String? @db.Text
  videoUrl      String? @db.Text
  linkUrl       String? @db.Text

  // Reach + spend RANGES — only populated for political/issue ads.
  impressionsLow  Int?
  impressionsHigh Int?
  spendLow        Int? // cents
  spendHigh       Int? // cents
  currency        String?

  // Publisher platforms the ad runs on (FACEBOOK, INSTAGRAM, AUDIENCE_NETWORK, MESSENGER).
  publisherPlatforms String[]

  // Lifecycle dates.
  adCreationTime  DateTime?
  adDeliveryStart DateTime?
  adDeliveryStop  DateTime?

  // Raw payload for forward-compat — Meta adds fields without notice.
  raw Json?

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  @@unique([advertiserId, externalId])
  @@index([advertiserId, status])
}

// ============================================================================
// EMAIL SUPPRESSION
// ============================================================================

// Email-address-level opt-out list. Populated by:
//   - RFC 8058 one-click unsubscribe POSTs from Gmail / Yahoo / Apple Mail
//   - Browser-based GET unsubscribes from the visible footer link
//   - Manual additions when someone replies "unsubscribe me" to a digest
//
// Every email send (sendBrandedEmail + the legacy safeSends) checks
// this list before dispatching to Resend. Suppressed addresses are
// silently dropped — we never re-send and we never error noisily,
// because that would create a re-send loop on retries.
//
// Lowercase email is the unique key; we lowercase on insert and on
// query.
model EmailSuppression {
  id    String @id @default(cuid())
  email String @unique // lowercased

  // Free-text reason. Common values:
  //   "one-click"      — Gmail/Yahoo POST unsubscribe
  //   "browser"        — clicked the URL in the email footer
  //   "manual"         — operator added via admin panel
  //   "complaint"      — Resend marked the recipient as a complainer
  //   "bounce"         — repeated hard bounces
  reason String?

  // Email category that triggered the suppression. Lets us evolve
  // toward a per-category opt-out (e.g. user opts out of digests but
  // wants to keep getting invoices) — for now we treat every
  // suppression as global so the user is always honored.
  category String?

  // Template name from the X-Entity-Ref-ID at unsub time, useful for
  // analytics ("which template generates the most unsubscribes").
  source String?

  unsubscribedAt DateTime @default(now())

  @@index([email])
}

// ============================================================================
// EMBEDDABLE POPUPS
// ----------------------------------------------------------------------------
// Operator-designed promo / referral / discount popups that get embedded
// on any external website via a single <script> tag (mirrors the chatbot
// embed architecture in public/embed/chatbot.js).
//
// Lifecycle:
//   1. Operator creates a PopupCampaign in /portal/popups with headline,
//      body, CTA, offer code, trigger config, and brand colors.
//   2. They paste a <script src="https://leasestack.co/embed/popup.js"
//      data-tenant="..."></script> tag in the <head> of their site.
//   3. The embed pulls config from /api/public/popup/config/[slug] and
//      renders the popup when the trigger fires (exit intent / scroll
//      depth / time on page).
//   4. Every render / dismiss / click / conversion writes a PopupEvent
//      row so the operator sees real conversion analytics in the portal.
// ============================================================================

enum PopupStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum PopupTrigger {
  EXIT_INTENT // mouse leaves the viewport top
  SCROLL_DEPTH // user has scrolled past N% of page height
  TIME_ON_PAGE // user has been on page for N seconds
  IDLE_TIME // user has been idle (no scroll/click/key) for N seconds
  IMMEDIATE // shown immediately on page load (use sparingly)
}

enum PopupPosition {
  CENTER // dimmed backdrop, centered modal
  BOTTOM_RIGHT // slide-in toast, non-blocking
  BOTTOM_LEFT
  TOP_BANNER // full-width banner stuck to top of viewport
}

enum PopupEventType {
  SHOWN
  DISMISSED
  CTA_CLICKED
  CONVERTED // lead form was submitted from inside the popup
}

// Visual treatment for the popup card. LIGHT is the v1 default and renders
// the exact same way pre-migration rows did. DARK swaps to a navy card
// with white-on-dark text (Telegraph "Limited Availability" reference).
// GRADIENT keeps a light card but adds a top accent bar built from the
// `gradientColors` stops.
enum PopupTheme {
  LIGHT
  DARK
  GRADIENT
}

model PopupCampaign {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Optional property scope. NULL = applies to every site this org has
  // installed the embed on; SET = only fires on pages where data-property
  // attribute matches this property's slug.
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  // Operator-facing label (not shown to visitors)
  name String

  // Lifecycle. Drafts never render. Paused respects analytics history
  // but stops new shows. Archived hides from the list.
  status PopupStatus @default(DRAFT)

  // ─── Copy (what the visitor sees) ─────────────────────────────────
  headline      String // ≤ 80 chars in UI but enforced as text in DB
  body          String  @db.Text
  ctaText       String // "Claim offer", "Apply now", etc.
  ctaUrl        String // where the CTA points; "#" or null-equivalent allowed
  // Optional promo / referral code shown in a copy-to-clipboard pill
  offerCode     String?
  // Optional secondary action — e.g. "Maybe later" dismiss copy override
  secondaryText String?

  // ─── Targeting + triggers ─────────────────────────────────────────
  trigger          PopupTrigger @default(EXIT_INTENT)
  triggerThreshold Int          @default(0) // seconds for TIME_ON_PAGE, percent for SCROLL_DEPTH

  // Allowlist of URL substrings the popup is allowed to fire on. Empty
  // array = every page. Examples: ["/floor-plans", "/apply"].
  targetUrlPatterns Json?

  // Show frequency — once per session (default) prevents popup fatigue.
  // "session" | "always" | "once_per_day"
  frequency String @default("session")

  // ─── Visual ───────────────────────────────────────────────────────
  position        PopupPosition @default(CENTER)
  primaryColor    String        @default("#2563EB") // brand blue
  textColor       String        @default("#0F172A") // near-black
  backgroundColor String        @default("#FFFFFF")

  // Optional hero image URL (full-bleed at top of popup)
  heroImageUrl String?

  // ─── Visual (phase 1 — design parity additions) ───────────────────
  // All nullable / soft-defaulted so pre-migration rows render identically
  // to before. The renderer + preview both check for presence and fall
  // through to the legacy treatment when these are NULL.
  eyebrowText String? // small caps label above headline
  accentColor String? // secondary accent (used for eyebrow + featured value)
  theme       PopupTheme @default(LIGHT)
  template    String? // slug of the template that seeded this row

  // Featured value card (price / rate callout — Telegraph-style)
  featuredLabel   String?
  featuredValue   String?
  featuredUnit    String?
  featuredCaption String?

  // Dual-CTA support — secondary button rendered next to primary when set
  secondaryCtaText String?
  secondaryCtaUrl  String?
  secondaryCtaIcon String? // "calendar" | "phone" | "external" | "arrow" | "none"
  primaryCtaIcon   String? // same enum-as-string

  // Tertiary dismiss link below CTAs (replaces secondaryText when set)
  dismissText String?

  // GRADIENT theme top-bar stops, e.g. ["#F5BC1A","#EC4899","#3B82F6"]
  gradientColors Json?

  // ─── Form capture (optional) ──────────────────────────────────────
  // When true, the popup includes an email + (optional) phone capture
  // form and posts to /api/public/leads with sourceDetail=popup:<id>.
  captureEmail Boolean @default(true)
  capturePhone Boolean @default(false)

  // ─── Analytics rollups (denormalized, refreshed on every event) ──
  shownCount     Int @default(0)
  dismissedCount Int @default(0)
  ctaClickCount  Int @default(0)
  convertedCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events PopupEvent[]

  @@index([orgId, status])
  @@index([orgId, propertyId])
  @@index([propertyId])
}

model PopupEvent {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  campaignId String
  campaign   PopupCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  type PopupEventType

  // Visitor identifiers (matched against Visitor when possible)
  sessionId   String? // popup-embed-issued session id
  anonymousId String? // browser cookie id from pixel if installed
  leadId      String? // populated on CONVERTED events

  // Source page where the event occurred
  pageUrl  String?
  referrer String?

  occurredAt DateTime @default(now())

  @@index([orgId, occurredAt])
  @@index([campaignId, type, occurredAt])
}

// ============================================================================
// BUG REPORTS
// ----------------------------------------------------------------------------
// In-app bug reports filed via the floating "Report bug" button on every
// portal/admin page. Persisted to our own DB so Adam has an admin
// triage queue + approval workflow on top of the existing GitHub
// issue + email side effects.
//
// Lifecycle:
//   1. User clicks the floating button, fills the form, attaches
//      screenshots → POST /api/bug-report
//   2. We write a BugReport row (status=PENDING), file a GitHub issue,
//      and email the ops inbox (parallel side effects)
//   3. Adam reviews at /admin/bug-reports, transitions through
//      IN_PROGRESS → FIXED → APPROVED (or REJECTED with a note)
//   4. Notes accumulate as JSON timeline on the row so the whole
//      conversation lives in one place
// ============================================================================

enum BugReportSeverity {
  LOW
  MEDIUM
  HIGH
  BLOCKER
}

enum BugReportStatus {
  PENDING // newly received, awaiting triage
  IN_PROGRESS // assigned, work started
  FIXED // engineering claims it's done — awaiting reporter / Adam approval
  APPROVED // verified fixed in production
  REJECTED // closed without fix (out of scope, wontfix, duplicate, etc.)
}

model BugReport {
  id String @id @default(cuid())

  // Reporter context — captured at submit time. We deliberately denormalize
  // the email + role so a future user deletion doesn't blank the history.
  // userId stays NULL when the user record is deleted.
  userId          String?
  user            User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  reporterEmail   String
  reporterRole    String? // UserRole at submit time
  reporterOrgId   String? // Org at submit time
  reporterOrgName String?

  title       String
  description String            @db.Text
  severity    BugReportSeverity @default(MEDIUM)
  status      BugReportStatus   @default(PENDING)

  // Page context — automatically captured by the floating button
  pageUrl   String?
  pagePath  String?
  userAgent String?
  viewport  String?

  // Screenshots / attachments — array of {url, pathname, contentType,
  // sizeBytes}. JSON because we expect 0-5 per report and don't need
  // join-by-image. Vercel Blob URLs.
  attachments Json @default("[]")

  // Side-effect refs from initial submission
  githubIssueNumber Int?
  githubIssueUrl    String?
  emailSent         Boolean @default(false)

  // Triage / approval state
  assignedToUserId String?
  resolutionNote   String?   @db.Text // why it was approved or rejected
  approvedAt       DateTime?
  approvedBy       String? // userId
  rejectedAt       DateTime?
  rejectedBy       String?

  // Append-only timeline of status changes + notes. Each entry:
  // { at: ISO, by: userId, byEmail: str, kind: "status"|"note"|"comment",
  //   from?: BugReportStatus, to?: BugReportStatus, text?: str }
  timeline Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@index([severity, status])
  @@index([reporterOrgId])
  @@index([userId])
}

// ============================================================================
// CREDENTIALS VAULT
// ----------------------------------------------------------------------------
// Encrypted-at-rest password vault for external-platform credentials
// (GA4, Meta Ads, AppFolio, bank logins, etc.). Each credential's secret
// is encrypted with AES-256-GCM using the owning Organization's DEK; the
// DEK is wrapped with a master KEK held in the VAULT_MASTER_KEK_B64 env
// var. DB dump alone yields nothing — attacker needs both DB + env.
//
// See docs/PRD-CREDENTIALS-VAULT.md for the full design + threat model.
// ============================================================================

model CredentialEntry {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // NULL = org-wide. Non-NULL = scoped to one property; property-level
  // RBAC (UserPropertyAccess) gates access via propertyWhereFragment.
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  // Clear-text metadata. The operator sees these in the list view —
  // the secret stays masked until they click reveal.
  name       String // "Google Analytics 4 — Telegraph Commons"
  platform   String? // free-text label: google-ads | meta-ads | appfolio | bank | ...
  websiteUrl String?
  username   String?
  notes      String?  @db.Text
  tags       String[] @default([])

  // Encrypted secret payload. AES-256-GCM with the org's DEK. All
  // values are base64-encoded so the DB column type stays portable.
  // secretCiphertext: variable-length ciphertext
  // secretIv: 12-byte random nonce
  // secretAuthTag: 16-byte GCM auth tag
  secretCiphertext String @db.Text
  secretIv         String
  secretAuthTag    String

  // Lifecycle metadata.
  createdById    String?
  lastRevealedAt DateTime?
  lastRotatedAt  DateTime?
  expiresAt      DateTime? // operator-set rotation reminder

  // Soft-delete so audit log references remain queryable.
  deletedAt   DateTime?
  deletedById String?

  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  accessLogs CredentialAccessLog[]

  @@index([orgId, propertyId])
  @@index([orgId, platform])
  @@index([orgId, deletedAt])
}

model CredentialAccessLog {
  id           String          @id @default(cuid())
  credentialId String
  credential   CredentialEntry @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  // Denormalized scope info so the log row survives the credential's
  // soft-delete (the relation is preserved, but the audit query
  // doesn't need to join just to display the actor + org).
  orgId            String
  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId           String?
  userEmail        String
  asImpersonatorId String? // agency staff impersonating a tenant

  action     String // "reveal" | "copy" | "edit" | "delete"
  ipAddress  String?
  userAgent  String?
  occurredAt DateTime @default(now())

  @@index([credentialId, occurredAt(sort: Desc)])
  @@index([orgId, occurredAt(sort: Desc)])
}

// ---------------------------------------------------------------------------
// ZillowReport — operator-pasted Zillow listing parsed into a frozen
// snapshot (payload) plus pre-computed investor math (calculations).
// Stored so operators can revisit a report without re-fetching Zillow
// (which both costs us a bot-risk hit and may have changed since the
// initial parse). Keyed by org so each tenant only sees their own.
// ---------------------------------------------------------------------------
model ZillowReport {
  id           String   @id @default(cuid())
  orgId        String
  userId       String?
  zillowUrl    String
  zpid         String
  payload      Json // parsed listing data (address, price, beds, etc.)
  calculations Json // computed investor math snapshot
  createdAt    DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
}

// ---------------------------------------------------------------------------
// AEO (AI Engine Optimization) citation tracking.
//
// Periodically queries ChatGPT / Perplexity / Claude / Gemini with realistic
// renter prompts ("best apartments in {neighborhood}, {city}") and records
// whether each tenant's property is cited in the AI assistant's response.
//
// Surfaces "AI search visibility" as a leading-indicator metric — the same
// way SEO surfaces "Google ranking visibility." Most operators have zero
// instrumentation here today; this becomes the first signal of whether
// they're showing up when prospective renters ask AI for recommendations.
//
// Touched by:
//   * lib/aeo/orchestrate.ts        (scan fan-out across engines × prompts)
//   * lib/aeo/engines/*.ts          (per-engine clients)
//   * lib/aeo/parse.ts              (cited / not-cited / competitor parser)
//   * app/api/cron/aeo-scan         (weekly cron, Mondays 02:00 UTC)
//   * app/api/portal/seo/aeo/scan   (on-demand "Scan now")
//   * app/portal/seo/aeo            (dashboard panel)
// ---------------------------------------------------------------------------
enum AeoEngine {
  CHATGPT
  PERPLEXITY
  CLAUDE
  GEMINI
}

enum AeoCitationStatus {
  CITED
  NOT_CITED
  COMPETITOR_CITED
}

model AeoCitationCheck {
  id                 String            @id @default(cuid())
  orgId              String
  propertyId         String?
  neighborhoodPageId String?
  /// Raw declarative claim (from NeighborhoodPage.aiCitations) the prompt
  /// was derived from. Null for property-level scans.
  claim              String?           @db.Text
  engine             AeoEngine
  prompt             String            @db.Text
  queryRunAt         DateTime          @default(now())
  status             AeoCitationStatus
  /// Whether the property/brand was *mentioned* anywhere in the response,
  /// regardless of whether a URL was cited. Searchable.ai-style breakdown:
  /// "Mentioned?" and "Cited?" are independent — an engine can mention you
  /// without linking, or cite a competitor while mentioning you in passing.
  /// Backfilled in the migration from `status IN (CITED, COMPETITOR_CITED)`.
  mentioned          Boolean           @default(false)
  /// Rank within the engine's answer (1 = top-mentioned). Null when not
  /// mentioned or when the engine returns an unranked enumeration.
  position           Int?
  responseText       String            @db.Text
  citedUrl           String?
  competitorsCited   String[]
  metadata           Json?

  org              Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  property         Property?         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  neighborhoodPage NeighborhoodPage? @relation(fields: [neighborhoodPageId], references: [id], onDelete: SetNull)

  @@index([orgId, queryRunAt])
  @@index([propertyId, queryRunAt])
  @@index([engine, queryRunAt])
  @@index([neighborhoodPageId, queryRunAt])
  @@index([orgId, mentioned, queryRunAt])
}

// ---------------------------------------------------------------------------
// NeighborhoodPage — operator-generated per-neighborhood landing pages
// rendered on the tenant marketing site at /n/<slug>. Built with two
// audiences in mind: Google (classic SEO ranking) AND the AI engines
// (ChatGPT, Perplexity, Claude, Gemini) that increasingly cite real-estate
// pages when prospects ask "where should I rent in <neighborhood>?". The
// `aiCitations` JSON column tracks the talking-points / "facts" the page
// is intended to be cited for so the AEO module can later verify whether
// the engines actually surface them. See lib/neighborhood/generate.ts for
// the Claude prompt used to draft the page.
// ---------------------------------------------------------------------------
model NeighborhoodPage {
  id              String                 @id @default(cuid())
  orgId           String
  propertyId      String? // optional anchor property
  city            String
  state           String?
  neighborhood    String
  slug            String // url-safe, unique per (orgId)
  title           String // SEO + page title
  metaDescription String // SEO meta
  intro           String                 @db.Text
  sections        Json // [{ heading, body }]
  faqs            Json // [{ question, answer }] — schema.org FAQPage
  aiCitations     Json? // metadata used by AEO module to verify citations later
  status          NeighborhoodPageStatus @default(DRAFT)
  publishedAt     DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  org       Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  property  Property?          @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  aeoChecks AeoCitationCheck[]

  @@unique([orgId, slug])
  @@index([orgId, status])
}

enum NeighborhoodPageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ============================================================================
// AD METRICS — historical retention (monthly rollups)
//
// Tier-based retention policy lives in `lib/billing/retention.ts`:
//   Foundation  -> 1 month daily, no monthly aggregates
//   Growth      -> 12 months daily, then aggregate to AdMetricMonthly
//   Scale/CUSTOM-> 24 months daily, then aggregate (CUSTOM may override
//                  via Organization.adDataRetentionMonths)
//
// Daily rollup cron (`/api/cron/ad-retention`, 03:30 UTC) reads each org's
// policy, rolls AdMetricDaily rows older than `dailyWindowMonths` into
// per-(org, adAccount, year, month) buckets, then deletes the daily rows.
//
// The dashboard reads stitch AdMetricDaily (recent) with AdMetricMonthly
// (older) so charts stay continuous across the boundary — see
// `lib/dashboard/queries.ts::getAdSpendKpi` and `app/portal/ads/page.tsx`.
// ============================================================================

model AdMetricMonthly {
  id          String @id @default(cuid())
  orgId       String
  adAccountId String

  // Calendar bucket, UTC. (year, month=1..12) is the dedup key alongside
  // (orgId, adAccountId). We store both as plain Int columns so range
  // filters stay index-friendly without date math at the DB layer.
  year  Int
  month Int

  impressions          Int   @default(0)
  clicks               Int   @default(0)
  spendCents           Int   @default(0)
  conversions          Float @default(0)
  conversionValueCents Int   @default(0)

  // Snapshot of how many daily rows were folded into this bucket. Useful
  // for audit + for a partial-month bucket the cron may keep refreshing
  // if it's still inside the daily window on the org's policy.
  daysAggregated Int @default(0)

  // Provenance: when did the aggregation job last write this row.
  aggregatedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([orgId, adAccountId, year, month])
  @@index([orgId, year, month])
  @@index([adAccountId, year, month])
}

// ============================================================================
// SELF-SERVE ONBOARDING AUTOMATION (three phases)
// ----------------------------------------------------------------------------
// Wraps the post-intake operator setup in a state machine with detectors,
// nudges, and a visible checklist on /portal. Three phases:
//
//   FOUNDATION  (week 1)  — platform working state
//   GROWTH      (week 2)  — first lead captured state
//   POLISH      (anytime) — optional enhancements (NOT auto-completed)
//
// State is lazy-initialized on first /portal landing via
// `getOrInitOnboardingProgress(orgId)`. Detectors in
// `lib/onboarding/step-detectors.ts` translate platform state into step
// completion. Phase advancement happens whenever every non-skipped step
// in the active phase flips COMPLETED.
// ============================================================================

enum OnboardingPhase {
  FOUNDATION
  GROWTH
  POLISH
  COMPLETED
}

enum OnboardingStepKey {
  // Foundation
  ADD_PROPERTY
  CONNECT_DATA_SOURCE
  CONFIRM_CONTACT_PREFS
  APPROVE_CHATBOT_PERSONA
  INSTALL_PIXEL
  // Growth
  VERIFY_LEAD_CAPTURE
  CONNECT_ADS
  REVIEW_FIRST_REPORT
  SET_REPUTATION_QUERIES
  // Polish
  CUSTOM_DOMAIN
  WHITE_LABEL
  GENERATE_NEIGHBORHOOD_PAGE
  CUSTOM_REPORT_PREFS
  INVITE_TEAMMATE
}

enum OnboardingStepStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

model OnboardingProgress {
  id    String       @id @default(cuid())
  orgId String       @unique
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  currentPhase          OnboardingPhase @default(FOUNDATION)
  foundationStartedAt   DateTime?
  foundationCompletedAt DateTime?
  growthStartedAt       DateTime?
  growthCompletedAt     DateTime?
  polishStartedAt       DateTime?
  completedAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  steps OnboardingStepProgress[]

  @@index([currentPhase])
}

model OnboardingStepProgress {
  id         String             @id @default(cuid())
  progressId String
  progress   OnboardingProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)

  phase   OnboardingPhase
  stepKey OnboardingStepKey

  status        OnboardingStepStatus @default(PENDING)
  completedAt   DateTime?
  skippedAt     DateTime?
  skippedReason String?

  // Free-form provenance — e.g. which property triggered ADD_PROPERTY, which
  // integration completed CONNECT_DATA_SOURCE. Useful for the checklist UI
  // ("Done — Telegraph Commons") and for replay/debug.
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([progressId, stepKey])
  @@index([progressId, phase])
  @@index([progressId, status])
}

// ============================================================================
// RentCast (https://developers.rentcast.io) — market intelligence cache
// + per-org budget tracking.
//
// Two-table design:
//   * RentCastSnapshot — per-call cache. Cache key collapses repeated
//     fetches for the same address + property attrs / zip code so a
//     single org doesn't burn through quota on duplicate calls.
//   * OrgRentCastUsage — per-org monthly budget. Defaults to RentCast's
//     50-call free-tier quota. The cache layer refuses fetches when
//     `requestsThisMonth >= monthlyBudget * hardCapMultiplier`, and the
//     property detail page swaps to an upsell card.
// ============================================================================

model RentCastSnapshot {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Optional — most snapshots are tied to a specific property, but
  // tool-use snapshots (ad-hoc address lookups for acquisitions, future
  // phase) leave this null. SET NULL is not used: if a Property row is
  // deleted, its per-property snapshots cascade out so the cache key
  // can be reclaimed cleanly.
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  // String-typed for forward compatibility — we'll add VALUE, LISTINGS,
  // PROPERTIES, etc. as future phases land. Stored as TEXT so we don't
  // need a Postgres enum migration for every new endpoint.
  // Accepted values today: RENT_LONG_TERM | MARKET_STATS | VALUE
  endpoint String

  // Normalized key for cache deduplication. See lib/rentcast/cache.ts
  // for the canonical shape: e.g.
  //   rent:2410-telegraph-ave-berkeley-ca-94704:2br:1ba:Apartment
  //   market:94704:Rental:6
  cacheKey String

  payload     Json
  fetchedAt   DateTime @default(now())
  expiresAt   DateTime
  // Credits consumed for this fetch. Currently always 1; reserved for
  // per-endpoint cost variance (e.g. comparable count multipliers).
  requestCost Int      @default(1)

  @@unique([orgId, cacheKey])
  @@index([orgId, endpoint, fetchedAt])
  @@index([propertyId])
}

model OrgRentCastUsage {
  id    String       @id @default(cuid())
  orgId String       @unique
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // YYYY-MM tracking window. Rolled over by lib/rentcast/budget.ts when
  // the current calendar month no longer matches; counter resets to 0
  // and lastResetAt updates.
  monthKey          String
  requestsThisMonth Int    @default(0)

  // Defaults to RentCast's Developer (free) tier quota. Admin can raise
  // per-org via the admin client detail page when the tenant upgrades.
  monthlyBudget Int @default(50)

  // Hard refuse fetches above (monthlyBudget * hardCapMultiplier). 1.5×
  // gives a soft buffer for the inevitable mis-clicks then surfaces an
  // upsell card on the property detail page.
  hardCapMultiplier Float @default(1.5)

  lastResetAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================================
// PropertyEvaluation — Acquisitions / Building Evaluator persistence.
//
// Backs the /portal/tools/value surface. Each row is one address an
// operator ran through the evaluator. We persist the raw RentCast
// payloads + the investor math so the report card can be re-rendered
// without spending more credits.
//
// Tenancy: orgId Cascade — deletes flow with the workspace. userId
// SetNull so deactivating a user preserves the historical record.
// Archived is a soft-delete column; the recent-list view defaults to
// non-archived. Cost per row: 3 RentCast credits (value + rent + market)
// at write time, deduped per address-shape via the snapshot cache.
// ============================================================================

model PropertyEvaluation {
  id     String       @id @default(cuid())
  orgId  String
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId String?
  user   User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Normalized cache-key form + original-cased display string.
  address        String
  addressDisplay String

  // Investor inputs. When askingPriceCents is null the math falls back
