// ============================================================================
// MARKETPLACE — platform-level lead pool, separate from operator portal
// ============================================================================
// The marketplace is intentionally NOT scoped to Organization. Every model
// below is a top-level resource. The marketplace is fed by Cursive Studio
// segments (configured in MarketplaceSyncSource) and replenished weekly
// by a cron at /api/cron/marketplace-replenish.
//
// Public browsing (/marketplace) hits MarketplaceLead through the masked
// repo (lib/marketplace/repo.ts). Only purchased leads return full PII.
// ============================================================================

enum MarketplaceLeadStatus {
  AVAILABLE   // Live in the pool, browsable, purchasable
  RESERVED    // Stripe checkout in flight (10-min hold)
  SOLD        // Purchased — appears only in the buyer's dashboard
  EXPIRED     // Past staleness window, no longer browsable
  RETIRED     // Manually removed by admin
}

enum MarketplaceLeadPropertyType {
  RENTAL
  SALE
  INVESTMENT
  COMMERCIAL
}

enum MarketplaceSyncSourceKind {
  CURSIVE_SEGMENT  // Pull from a Cursive Studio segment ID
  CURSIVE_AUDIENCE // Pull from a Cursive Audience List ID
  MANUAL           // Operator-uploaded CSV / API ingest
}

enum MarketplaceSyncRunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

// One row per (Cursive segment, property-type) feed that fills the marketplace.
// Admin configures these. The cron iterates all enabled sources and runs them.
model MarketplaceSyncSource {
  id   String @id @default(cuid())
  name String // operator-friendly label

  kind            MarketplaceSyncSourceKind
  // For CURSIVE_*: the AL segment / audience id this source pulls from.
  externalId      String?
  // Default property type assigned to leads from this source. Leads can be
  // re-classified per-record by the enrichment step.
  defaultPropertyType MarketplaceLeadPropertyType
  // Default market (city/region). Used when the source itself doesn't carry
  // per-record geo (e.g. a national segment we segment by zip downstream).
  defaultMarket   String?

  // Score floor — leads below this threshold get ingested but flipped to
  // EXPIRED immediately. Default 50 (segments with verified identity but
  // no behavioural signals can still produce sellable leads).
  minScoreFloor   Int     @default(50)

  // Baseline score applied when the raw Cursive payload doesn't carry
  // strong behavioural signals (no listings-viewed, no urgency flags).
  // Use this to express "every member of this curated segment is at
  // least worth this much" — e.g. a high-intent buyer audience would
  // set this to 70 so identity-only leads still surface.
  baselineScore   Int     @default(50)

  // When true, any member missing ANY of the required enrichment fields
  // (firstName, lastName, email, phone, companyName, companyState,
  // linkedinUrl, mobilePhone, incomeRange, gender, businessEmail, city)
  // is REJECTED at ingest. The marketplace pool stays at premium
  // quality — every browseable lead is fully enriched. Default false
  // for backward compat with existing sources.
  requireFullEnrichment Boolean @default(false)

  // Default per-lead listing price in cents. The scoring engine tiers
  // up from here based on intent score (hot leads cost more).
  defaultPriceCents Int   @default(5000)

  // Cron cadence is fixed to weekly (Mondays 06:00 UTC) but the source can
  // be paused via `enabled` if we need to halt replenishment.
  enabled         Boolean @default(true)

  // Last successful run pointer + counters for the admin dashboard.
  lastRunAt           DateTime?
  lastSuccessAt       DateTime?
  lastIngestedCount   Int       @default(0)
  lastEnrichedCount   Int       @default(0)
  lastExpiredCount    Int       @default(0)

  // Optional override of the global CURSIVE_API_KEY env when this source
  // talks to a separate Cursive workspace.
  cursiveApiKeyEnc    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs  MarketplaceSyncRun[]
  leads MarketplaceLead[]

  @@index([enabled])
  @@index([kind])
}

// Idempotent log of every replenishment run. One row per cron tick per source.
model MarketplaceSyncRun {
  id       String                 @id @default(cuid())
  sourceId String
  source   MarketplaceSyncSource  @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  status   MarketplaceSyncRunStatus @default(PENDING)

  // Counters populated as the run progresses.
  fetchedCount    Int    @default(0) // members returned by Cursive
  enrichedCount   Int    @default(0) // members that passed enrichment + score floor
  upsertedCount   Int    @default(0) // MarketplaceLead rows created OR refreshed
  newCount        Int    @default(0) // brand new leads added to the pool
  refreshedCount  Int    @default(0) // existing leads re-enriched
  expiredCount    Int    @default(0) // leads aged out by this run
  failedCount     Int    @default(0)

  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  errorMessage String?   @db.Text

  // Snapshot of the cursor / page state — if a run fails mid-stream, the
  // next run can resume from here instead of starting over.
  resumeCursor String?

  @@index([sourceId, startedAt(sort: Desc)])
  @@index([status])
}

// The actual sellable lead. One row per resolved identity per source.
// Uniqueness is (sourceId, cursiveProfileId) so re-runs of the same Cursive
// segment refresh the existing row instead of creating duplicates.
model MarketplaceLead {
  id       String                 @id @default(cuid())
  sourceId String
  source   MarketplaceSyncSource  @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  // Optional seller credit — set when the lead came in via a seller-side
  // import (CSV upload or seller-attributed Cursive segment). Null means
  // platform-direct (we keep 100%).
  sellerId String?
  seller   MarketplaceSeller? @relation(fields: [sellerId], references: [id], onDelete: SetNull)

  // Stable identity from Cursive — the primary dedupe key for replenishment.
  cursiveProfileId String

  // Display / browse metadata. All fields are populated by the enrichment
  // step from the Cursive payload. PII fields are returned masked through
  // the public browse API and only un-masked after purchase.

  // Identity — basic
  firstName    String?
  lastName     String?
  email        String?   // verified personal email
  phone        String?   // verified personal landline / primary phone
  age          Int?
  gender       String?   // "Male" | "Female" | other free-form
  photoUrl     String?   // generated avatar URL (deterministic from profile id)

  // Identity — extended enrichment (Cursive Studio rich segments)
  companyName    String?  // employer / household business
  companyState   String?  // 2-letter state code of employer
  businessEmail  String?  // verified work email
  mobilePhone    String?  // verified mobile (separate from primary phone)
  linkedinUrl    String?  // https://linkedin.com/in/... or company URL
  incomeRange    String?  // "$150K–$250K" or similar pretty band

  // Geo (personal address)
  city         String?
  state        String?
  postalCode   String?
  market       String    // canonical market label (e.g. "Brooklyn", "Miami")

  // Property type + behavioural intent
  propertyType MarketplaceLeadPropertyType
  intentScore  Int       // 0..100 composite — see lib/marketplace/scoring.ts
  budgetLabel  String?   // "$680K – $920K" or "$3.8K – $5.2K/mo"
  budgetMinCents Int?
  budgetMaxCents Int?
  signal       String?   // one-line behavioural summary ("Viewed 23 listings · 7d")
  timeline     String?   // "0–30 days", etc.

  // Raw intent payload from Cursive — full segment membership list, last-seen,
  // search radius, etc. Used by lib/marketplace/scoring.ts and surfaced on the
  // detail page after purchase.
  intentPayload Json?

  // Marketplace economics
  priceCents   Int       @default(5000)
  status       MarketplaceLeadStatus @default(AVAILABLE)

  // Lifecycle pointers
  firstSeenAt   DateTime @default(now())
  lastEnrichedAt DateTime @default(now())
  // Stale-after timestamp. After this point the cron flips the lead to
  // EXPIRED. Default = lastEnrichedAt + 14 days. Refreshed on every
  // weekly replenish to keep hot leads alive.
  expiresAt     DateTime

  // When a lead is sold the buyer id is denormalized here for fast lookups.
  soldToBuyerId String?
  soldAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sourceId, cursiveProfileId])
  @@index([status, intentScore(sort: Desc)])
  @@index([status, market, propertyType])
  @@index([status, expiresAt])
  @@index([sourceId, status])
  @@index([cursiveProfileId])
  @@index([sellerId, status])

  purchases MarketplacePurchase[]
}

// ----------------------------------------------------------------------------
// Buyer-side: standalone accounts, NOT linked to Organization / User. Magic
// link auth via Resend. Owns purchases and stream subscriptions.
// ----------------------------------------------------------------------------

model MarketplaceBuyer {
  id String @id @default(cuid())

  // Magic-link identity. Email is the only login factor — no passwords.
  email     String  @unique
  // Display name picked up from the buyer at first purchase. Optional —
  // not required to sign in.
  fullName  String?
  // Business context for the email receipt and Stripe metadata.
  companyName String?
  phone     String?

  // One-time-use sign-in token. SHA-256 hash of the random token we sent
  // in the magic-link email; null when no link is outstanding. Tokens
  // expire after 30 minutes via signInExpiresAt.
  signInTokenHash    String?
  signInExpiresAt    DateTime?
  signInRequestedAt  DateTime?

  // Stripe customer pointer, created on first checkout. Reused for every
  // subsequent purchase so Stripe carries the buyer's saved payment
  // methods + receipt history.
  stripeCustomerId String? @unique

  // Webhook destination — when a stream auto-purchases a lead, we POST
  // the full PII to this URL (signed with webhookSecret).
  webhookUrl       String?
  webhookSecretEnc String?

  // Lifecycle
  lastSignInAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchases MarketplacePurchase[]
  streams   MarketplaceStream[]

  @@index([signInTokenHash])
  @@index([stripeCustomerId])
}

enum MarketplacePurchaseStatus {
  PENDING       // Stripe checkout in flight
  PAID          // Stripe confirmed payment; PII released to buyer
  REFUNDED      // Manual refund issued; PII access revoked
  FAILED        // Checkout failed / expired
}

// One row per buyer-buys-a-lead transaction. PII access is gated through
// this table — server components check ownership before returning full
// lead fields on /marketplace/[id].
model MarketplacePurchase {
  id       String           @id @default(cuid())

  leadId   String
  lead     MarketplaceLead  @relation(fields: [leadId], references: [id], onDelete: Restrict)

  buyerId  String
  buyer    MarketplaceBuyer @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  // How this purchase originated:
  //   "DIRECT"  — buyer clicked Buy on /marketplace/[id]
  //   "STREAM"  — auto-purchased by a saved MarketplaceStream
  origin    String @default("DIRECT")

  // Optional pointer to the stream that triggered an auto-purchase.
  streamId  String?
  stream    MarketplaceStream? @relation(fields: [streamId], references: [id], onDelete: SetNull)

  // Stripe pointers
  stripeCheckoutSessionId String?  @unique
  stripePaymentIntentId   String?  @unique

  priceCents Int
  currency   String @default("usd")
  status     MarketplacePurchaseStatus @default(PENDING)

  // Revenue split snapshot — taken at purchase time so the seller's
  // accrued credit is locked even if revShareBps changes later. Null for
  // platform-direct leads (no seller).
  sellerIdAtSale     String?
  sellerShareBps     Int?    // basis points (7000 = 70%)
  sellerShareCents   Int?    // computed: priceCents * sellerShareBps / 10000
  platformShareCents Int?    // computed: priceCents - sellerShareCents

  // Receipts + emails
  receiptUrl       String?
  piiDeliveredAt   DateTime?
  receiptSentAt    DateTime?

  // Refund context, if any
  refundedAt       DateTime?
  refundReason     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([buyerId, createdAt(sort: Desc)])
  @@index([leadId])
  @@index([status])
}

// Saved buyer filter. New leads matching the filter are eligible for
// auto-purchase in the post-replenish matching cron (Phase 2b).
model MarketplaceStream {
  id      String           @id @default(cuid())
  buyerId String
  buyer   MarketplaceBuyer @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  name    String

  // Filter criteria — same shape as the public browse endpoint params.
  market         String?     // canonical market label (e.g. "Texas"), null = any
  propertyType   MarketplaceLeadPropertyType?  // null = any
  minIntent      Int @default(70)
  maxPriceCents  Int @default(20000)

  // How much the buyer is willing to spend in a 7-day rolling window
  // (cents). The Phase 2b matching cron stops auto-purchasing once
  // weeklyBudgetCents is consumed.
  weeklyBudgetCents Int @default(50000)

  // Lifecycle controls — buyer can pause without deleting.
  enabled Boolean @default(true)

  // Last time the matching cron looked at this stream + how many leads
  // it has auto-purchased lifetime.
  lastMatchedAt   DateTime?
  totalPurchases  Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchases MarketplacePurchase[]

  @@index([buyerId, enabled])
  @@index([enabled, lastMatchedAt])
}

// ----------------------------------------------------------------------------
// Seller side — operators who BRING leads INTO the marketplace and earn a
// revenue share when those leads sell. Mirrors the buyer-side architecture:
//   - Standalone magic-link auth (no Clerk)
//   - Two ingest paths: (a) point at a Cursive segment id with their own
//     CURSIVE_API_KEY override, (b) CSV upload via the seller dashboard
//   - Every MarketplaceLead carries an optional sellerId so the webhook
//     can credit the right operator on purchase
//   - Payouts accrue per seller and clear via MarketplaceSellerPayout
// ----------------------------------------------------------------------------

enum MarketplaceSellerStatus {
  ACTIVE
  PAUSED   // seller can sign in but new leads don't surface in browse
  BANNED
}

model MarketplaceSeller {
  id String @id @default(cuid())

  email     String  @unique
  fullName  String?
  companyName String?
  phone     String?

  // Magic-link auth (same shape as MarketplaceBuyer)
  signInTokenHash    String?
  signInExpiresAt    DateTime?
  signInRequestedAt  DateTime?

  // Revenue share — fraction of each sale credited to this seller, in
  // basis points (so 7000 = 70%). Platform keeps (10000 - revShareBps).
  // Tunable per seller; default 7000 = 70/30 in seller's favor.
  revShareBps Int @default(7000)

  // Lifetime accrued + paid out, in cents. The webhook bumps `accrued`
  // on every PAID purchase; MarketplaceSellerPayout decrements via the
  // payout flow (Phase 2c).
  accruedCents       Int @default(0)
  paidOutCents       Int @default(0)
  unpaidOwedCents    Int @default(0)

  // Lead counts for the dashboard.
  totalLeadsContributed Int @default(0)
  totalLeadsSold        Int @default(0)

  // Stripe Connect account id (for direct payouts). Optional — without
  // it, payouts are tracked but executed manually.
  stripeConnectAccountId String?

  status MarketplaceSellerStatus @default(ACTIVE)

  // Optional per-seller Cursive API key override. Encrypted with the same
  // AES-GCM helper used for ad-cred storage.
  cursiveApiKeyEnc String?

  lastSignInAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  leads   MarketplaceLead[]
  payouts MarketplaceSellerPayout[]

  @@index([signInTokenHash])
  @@index([status])
}

enum MarketplacePayoutStatus {
  PENDING
  PAID
  FAILED
}

// One row per payout to a seller. Created by admin (or future automated
// weekly cron). Decrements the seller's unpaidOwedCents on success.
model MarketplaceSellerPayout {
  id        String                 @id @default(cuid())
  sellerId  String
  seller    MarketplaceSeller      @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  amountCents Int
  currency    String  @default("usd")
  status      MarketplacePayoutStatus @default(PENDING)

  // Stripe transfer id when paid via Stripe Connect; null for manual payouts.
  stripeTransferId String?
  note             String? @db.Text

  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([sellerId, createdAt(sort: Desc)])
  @@index([status])
}
