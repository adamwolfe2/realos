// ============================================================================
// CORE TENANCY
// ============================================================================

model Organization {
  id               String      @id @default(cuid())
  name             String
  shortName        String?
  slug             String      @unique // {slug}.platformdomain.com
  orgType          OrgType     @default(CLIENT)
  productLine      ProductLine @default(STUDENT_HOUSING)
  clerkOrgId       String?     @unique
  stripeCustomerId String?     @unique

  // Optional override for AL credentials when an AUDIENCE_SYNC org wants to
  // use their own AudienceLab account instead of the platform-shared key.
  cursiveApiKeyOverride String?

  // Property classification
  propertyType       PropertyType        @default(RESIDENTIAL)
  residentialSubtype ResidentialSubtype?
  commercialSubtype  CommercialSubtype?

  // Tenant status
  status       TenantStatus @default(INTAKE_RECEIVED)
  launchedAt   DateTime?
  atRiskReason String?

  // Branding (for tenant marketing site + portal)
  logoUrl        String?
  primaryColor   String? @default("#000000")
  secondaryColor String?
  brandFont      String?

  // Contact
  primaryContactName  String?
  primaryContactEmail String?
  primaryContactPhone String?
  primaryContactRole  String?

  // Location (company HQ, not properties)
  hqAddressLine1 String?
  hqCity         String?
  hqState        String?
  hqPostalCode   String?

  // Subscription
  subscriptionTier      SubscriptionTier?
  subscriptionStatus    SubscriptionStatus?
  subscriptionStartedAt DateTime?
  mrrCents              Int?                @default(0)
  buildFeePaidCents     Int?                @default(0)
  adSpendMarkupPct      Float?              @default(0.15) // 15% default

  // Optional override for the historical ad-metric retention window
  // (months of AdMetricDaily granularity kept before rollup into
  // AdMetricMonthly). NULL = use tier default from
  // `lib/billing/retention.ts`. Only honored on SCALE / CUSTOM tiers;
  // Foundation + Growth ignore overrides.
  adDataRetentionMonths Int?

  // Selected modules (a la carte flags)
  moduleWebsite        Boolean @default(true)
  modulePixel          Boolean @default(false)
  moduleChatbot        Boolean @default(false)
  moduleGoogleAds      Boolean @default(false)
  moduleMetaAds        Boolean @default(false)
  moduleSEO            Boolean @default(false)
  moduleEmail          Boolean @default(false)
  moduleOutboundEmail  Boolean @default(false)
  moduleReferrals      Boolean @default(false)
  moduleCreativeStudio Boolean @default(false)
  moduleLeadCapture    Boolean @default(true)
  // Embeddable popup module — operators design promo / referral /
  // discount popups in /portal/popups and paste a one-line script tag
  // on any external site. Same architecture as moduleChatbot.
  modulePopups         Boolean @default(false)

  // ── Report cadence config (Norman bug #100) ───────────────────────
  // Drives the daily / weekly / monthly cron auto-send loop. NONE
  // (default) preserves the existing white-glove behavior: the cron
  // generates a DRAFT only and the operator manually clicks "Share"
  // or "Email" to ship it. The other values opt into auto-send to
  // the recipient list below the moment the snapshot is generated.
  reportCadence       String   @default("none") // none | daily | weekly | monthly
  reportRecipients    String[] @default([]) // explicit email addresses
  reportAutoSend      Boolean  @default(false) // master enable for auto-send
  // Online reputation surface — /portal/reputation aggregates Google /
  // Apartments.com / Yelp review pulls, sentiment, and reply workflow.
  // Off by default; activated when the reputation add-on lands.
  moduleReputation    Boolean  @default(false)
  // AEO + briefing + reports intelligence bucket. Gates
  // /portal/insights, /portal/briefing, /portal/reports — all of which
  // depend on the same underlying signal pipeline.
  moduleInsights      Boolean  @default(false)
  // RentCast-powered market intelligence on the property detail page
  // (estimated market rent, submarket median, nearby comparables,
  // hot/cold market badge). Off by default — Norman feedback (May 22)
  // is that residential operators don't want rent-comp data surfaced
  // alongside their digital-marketing dashboards, same direction as
  // bugs #71/#77/#97 (no rent-roll metrics anywhere). Agency operators
  // can flip it on per tenant from /admin/clients/[id] when there's
  // ever a use case for it.
  moduleMarketIntelligence Boolean @default(false)
  // Cross-channel attribution surface (/portal/attribution). Direct
  // competitor to Clarity Attribution; included as the headline
  // value-prop module on Growth+ tiers.
  moduleAttribution   Boolean  @default(false)
  // Post-lease PMS surface. Groups residents, renewals, work orders,
  // and applications — every page that hangs off AppFolio operational
  // sync. Off until the AppFolio integration is wired + healthy.
  moduleResidents     Boolean  @default(false)
  // Tour bookings (/portal/tours). Sourced from the public booking
  // form and API-key ingest, NOT AppFolio. Kept separate from the PMS
  // bucket so non-AppFolio tenants can still light it up.
  moduleTours         Boolean  @default(false)
  // Inbox-style chatbot conversations surface (/portal/conversations).
  // Distinct from moduleChatbot, which gates the bot itself; this
  // gates the read-side conversation pipeline. Both usually flip on
  // together but can be unbundled for read-only deployments.
  moduleConversations Boolean  @default(false)
  // Credentials vault. Paid add-on. Stores per-property and org-wide
  // passwords for external platforms (GA4, Meta Ads, AppFolio, etc.)
  // using envelope encryption — per-org DEK wrapped by a master KEK
  // in env. See docs/PRD-CREDENTIALS-VAULT.md.
  moduleVault         Boolean  @default(false)

  // Wrapped data-encryption key for this org's credential vault.
  // 32-byte AES-256-GCM key, generated on first vault row creation,
  // wrapped with the master KEK from VAULT_MASTER_KEK_B64 env var.
  // Null until the operator creates their first credential. Rotating
  // the master KEK re-wraps these (cheap); rotating an org's DEK
  // requires re-encrypting that org's credentials (still scriptable).
  vaultDekWrapped Bytes?
  vaultDekNonce   Bytes? // 12-byte GCM nonce used to wrap the DEK
  vaultEnabledAt  DateTime?

  // Site hosting mode
  bringYourOwnSite Boolean @default(false)

  /// How published content is delivered. Controls what happens when an
  /// operator clicks "Submit for approval" on a ContentDraft or
  /// NeighborhoodPage:
  ///
  ///   HOSTED              — auto-publish to the LeaseStack tenant site
  ///                         at tenant.com/n/<slug> (default for clients
  ///                         on the Hosted Marketing Site Managed plan).
  ///   EXTERNAL_VIA_ADMIN  — submit to /admin/content-approvals. Adam
  ///                         pastes the MDX into the client's external
  ///                         repo (separate Vercel project), clicks
  ///                         "Mark deployed" once live. Default for new
  ///                         orgs since most clients host elsewhere.
  ///   EXTERNAL_VIA_WEBHOOK — POST page payload to client's webhook URL.
  ///                         (Future — not implemented yet.)
  ///   EXTERNAL_VIA_GITHUB  — open PR on client's repo via GitHub App.
  ///                         (Future — requires App installation.)
  publishMode      PublishMode @default(EXTERNAL_VIA_ADMIN)

  // White-label workspace ($499/mo add-on, ls_addon_white_label).
  // When `whiteLabel` is true and the override fields are populated, every
  // operator-facing brand surface (portal layout, tenant marketing site,
  // outbound email display name + footer) swaps the LeaseStack default
  // for the operator's own brand. The actual sending address stays as
  // team@leasestack.co so DMARC/DKIM alignment is preserved — only the
  // display name and visible footer change.
  //
  // Activation: lib/billing/catalog.ts → ADDONS entry. Stripe webhook
  // flips whiteLabel=true when ls_white_label_monthly_v1 lands on the
  // subscription. Deactivation flips it back to false on cancel.
  // See lib/brand/effective.ts for the resolver consumed by every surface.
  whiteLabel             Boolean @default(false)
  whiteLabelBrandName    String?
  whiteLabelLogoUrl      String?
  whiteLabelPrimaryColor String?

  // Relationships
  users                   User[]
  properties              Property[]
  domains                 DomainBinding[]
  tenantSiteConfig        TenantSiteConfig?
  leads                   Lead[]
  visitors                Visitor[]
  chatbotConversations    ChatbotConversation[]
  creativeRequests        CreativeRequest[]
  adAccounts              AdAccount[]
  adCampaigns             AdCampaign[]
  emailSubscribers        EmailSubscriber[]
  intakeSubmission        IntakeSubmission?
  projects                Project[]
  auditEvents             AuditEvent[]
  clientNotes             ClientNote[]
  // Was `cursiveIntegration` (singular, one-to-one) before the
  // multi-property migration. Now an array because tenants can have
  // one pixel per property plus an optional legacy org-wide row
  // (propertyId = NULL). Consumers should use the helpers in
  // lib/integrations/per-property.ts instead of reading directly.
  cursiveIntegrations     CursiveIntegration[]
  pixelProvisionRequests  PixelProvisionRequest[]
  appfolioIntegration     AppFolioIntegration?
  seoIntegrations         SeoIntegration[]
  seoSnapshots            SeoSnapshot[]
  seoQueries              SeoQuery[]
  seoLandingPages         SeoLandingPage[]
  addresses               Address[]
  apiKeys                 ApiKey[]
  integrationRequests     IntegrationRequest[]
  visitorSessions         VisitorSession[]
  visitorEvents           VisitorEvent[]
  chatbotEngagements      ChatbotEngagement[]
  notifications           Notification[]
  insights                Insight[]
  clientReports           ClientReport[]
  conversationFlags       ConversationFlag[]
  reputationScans         ReputationScan[]
  reputationMentions      PropertyMention[]
  adLibraryAdvertisers    AdLibraryAdvertiser[]
  audienceSegments        AudienceSegment[]
  audienceDestinations    AudienceDestination[]
  audienceSyncRuns        AudienceSyncRun[]
  audienceSchedules       AudienceSyncSchedule[]
  residents               Resident[]
  leases                  Lease[]
  workOrders              WorkOrder[]
  websiteBuildRequests    WebsiteBuildRequest[]
  siteRequests            SiteRequest[]
  popupCampaigns          PopupCampaign[]
  popupEvents             PopupEvent[]
  credentialEntries       CredentialEntry[]
  credentialAccessLogs    CredentialAccessLog[]
  zillowReports           ZillowReport[]
  aeoChecks               AeoCitationCheck[]
  neighborhoodPages       NeighborhoodPage[]
  onboardingProgress      OnboardingProgress?
  // SEO/AEO Agent backrefs — Phase 1
  seoActionRecs           SeoActionRecommendation[]
  contentDrafts           ContentDraft[]
  siteIntelligence        SiteIntelligence?
  contentQuotas           MonthlyContentQuota[]
  /// Per-org override of plan-based content quotas. JSON of
  /// { BLOG_POST: 100, NEIGHBORHOOD_PAGE: 50, ... }. Set from
  /// /admin/clients/[id] when a client needs extra capacity outside
  /// their plan tier.
  contentQuotaOverride    Json?
  seoScoreHistory         SeoScoreHistory[]
  propertyCompetitorScans PropertyCompetitorScan[]
  // DataforSEO ingestion (Phase 1.5)
  seoTargetQueries        SeoTargetQuery[]
  seoScanJobs             SeoScanJob[]
  serpRankings            SerpRanking[]
  onPageAudits            OnPageAudit[]
  backlinkSummaries       BacklinkSummary[]
  // DataforSEO ingestion (Phase 2)
  onPageInstantAudits     OnPageInstantAudit[]
  localPackRankings       LocalPackRanking[]
  rankedKeywords          RankedKeyword[]
  keywordIntersections    KeywordIntersection[]
  queryLandingDaily       QueryLandingDaily[]

  // Per-property + per-org RentCast market intelligence cache + usage
  // counter. Both are populated lazily — only orgs that actually open
  // the Market Intelligence section on a property detail page allocate
  // rows. See lib/rentcast/* and prisma/migrations/20260522_rentcast_phase1.
  rentCastSnapshots   RentCastSnapshot[]
  rentCastUsage       OrgRentCastUsage?
  propertyEvaluations PropertyEvaluation[]

  // Onboarding checklist dismissed by the operator. When false, the
  // first-login walkthrough renders on /portal.
  onboardingDismissed Boolean @default(false)

  // Self-serve onboarding wizard state. `onboardingStep` advances as the
  // user clears each step; null means they haven't entered the wizard
  // yet (legacy orgs created before the trial-first model). `chosenTier`
  // captures what they picked during the wizard so the trial unlocks
  // exactly those entitlements (not always Scale; respects what they
  // intend to pay for at conversion).
  //
  // Trial model: at the end of the wizard we set trialStartedAt + 14d
  // trialEndsAt. No card is collected. On day 14, the workspace gates
  // to read-only and the activate-subscription flow takes over.
  // subscriptionStatus becomes TRIALING during this window and flips to
  // ACTIVE when the customer completes Stripe Checkout for N properties.
  onboardingStep String?
  chosenTier     SubscriptionTier?
  trialStartedAt DateTime?
  trialEndsAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgType, status])
  @@index([slug])
  @@index([clerkOrgId])
}

model User {
  id          String  @id @default(cuid())
  clerkUserId String  @unique
  email       String  @unique
  firstName   String?
  lastName    String?
  phone       String?
  avatarUrl   String?

  role  UserRole     @default(CLIENT_VIEWER)
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  auditEvents           AuditEvent[]
  tasksAssigned         ProjectTask[]         @relation("TaskAssignee")
  notifications         Notification[]
  websiteBuildsAssigned WebsiteBuildRequest[] @relation("WebsiteBuildAssignee")
  siteRequestsAssigned  SiteRequest[]         @relation("SiteRequestAssignee")

  // Per-property access grants. ZERO rows = unrestricted (org-wide
  // access — preserves the legacy behavior so existing users aren't
  // affected by the property-RBAC rollout). ONE OR MORE rows = the
  // user can ONLY see those properties' data on every portal page.
  propertyAccess      UserPropertyAccess[]
  bugReports          BugReport[]
  propertyEvaluations PropertyEvaluation[]

  // Command Center: last time this operator opened the briefing view. Used to
  // compute "what's new since you last looked" deltas on /portal/briefing.
  lastBriefingViewedAt DateTime?

  @@index([orgId])
  @@index([role])
}

// ---------------------------------------------------------------------------
// UserPropertyAccess — fine-grained gate for "this user can only see
// these properties." Sits alongside the org-level User.orgId gate; both
// are enforced. Designed so:
//   - 0 rows for a user => unrestricted (org-wide). Default for every
//     existing user, so this migration ships without breaking anyone.
//   - 1+ rows => restricted. The user's view is locked to those property
//     ids on every page (pages also filter their property dropdown to
//     show only the allowed options).
//
// Property-level role override (`role`) is reserved for a future PR
// where, e.g., a Telegraph Commons leasing agent might be a
// CLIENT_ADMIN on Telegraph but a CLIENT_VIEWER on a sister property.
// Not used at gate time today.
// ---------------------------------------------------------------------------
model UserPropertyAccess {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  // Optional per-property role override. NULL = inherit User.role.
  role UserRole?

  // Audit trail: who granted this access + when.
  grantedBy String?
  grantedAt DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

model ApiKey {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  name      String // operator-chosen label, e.g. "Zapier production"
  keyPrefix String // first ~12 chars of the raw key, for display only (re_live_aB12...)
  keyHash   String   @unique // SHA-256 of the full raw key; the raw key is never stored
  scopes    String[] // e.g. ["ingest:lead", "ingest:visitor", "ingest:tour", "ingest:chatbot"] or ["*"]

  // Expiration / rotation. expiresAt is optional ("never" = null). The
  // auth check rejects keys past this timestamp the same way it rejects
  // revokedAt. rotatedFromKeyId is a forward-only foreign key (no back
  // reference needed; queries that want the chain do an explicit
  // findMany on rotatedFromKeyId). (audit BUG #5)
  expiresAt        DateTime?
  rotatedFromKeyId String?

  createdByUserId String?
  lastUsedAt      DateTime?
  lastUsedIp      String?
  usageCount      Int       @default(0)
  revokedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([keyHash])
  @@index([expiresAt])
}

model DomainBinding {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  hostname       String  @unique // telegraphcommons.com
  isPrimary      Boolean @default(false)
  vercelDomainId String?
  sslStatus      String? // pending, active, failed
  dnsConfigured  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

model TenantSiteConfig {
  id    String       @id @default(cuid())
  orgId String       @unique
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Site content
  siteTitle       String?
  tagline         String?
  heroHeadline    String?
  heroSubheadline String?
  heroImageUrl    String?
  aboutCopy       String? @db.Text

  // CTA config
  primaryCtaText String? @default("Apply Now")
  primaryCtaUrl  String?
  phoneNumber    String?
  contactEmail   String?

  // SEO
  metaTitle       String?
  metaDescription String?
  ogImageUrl      String?

  // Feature toggles (site-level)
  showListings     Boolean @default(true)
  showFloorPlans   Boolean @default(true)
  showAmenities    Boolean @default(true)
  showReviews      Boolean @default(false)
  showBlog         Boolean @default(false)
  enableExitIntent Boolean @default(true)
  enableChatbot    Boolean @default(false)
  enablePixel      Boolean @default(false)

  // Chatbot config
  chatbotEnabled            Boolean            @default(false)
  chatbotAvatarUrl          String?
  chatbotPersonaName        String?
  chatbotGreeting           String?
  // Optional second message sent right after the greeting on first
  // open. Was previously a HARDCODED template inside public/embed/
  // chatbot.js ("We just had rooms come available at {brandName}
  // starting at $X/mo. What can I help you with?") — operators had
  // no way to edit it. Now it's a full string with optional
  // placeholders: {property_name}, {starting_rent}, {open_count},
  // {next_available}. Set to null/empty to suppress the second
  // message entirely (greeting only).
  chatbotFollowUpMessage    String?            @db.Text
  chatbotTeaserText         String?
  chatbotBrandColor         String?
  chatbotCaptureMode        ChatbotCaptureMode @default(ON_INTENT)
  chatbotKnowledgeBase      String?            @db.Text
  chatbotIdleTriggerSeconds Int                @default(5)

  // Tenant analytics. When ga4MeasurementId is set, the embed widget will
  // lazy-load gtag.js with that ID on the host page if no dataLayer/gtag is
  // already present, then fire chatbot_opened / chatbot_lead_captured events
  // directly into the tenant's GA4 property. Bypasses GTM entirely.
  ga4MeasurementId    String?
  exitIntentHeadline  String?
  exitIntentBody      String?
  exitIntentCtaText   String?
  exitIntentOfferCode String?

  // Raw JSON for extensibility
  customJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// REAL ESTATE ENTITIES
// ============================================================================

model Property {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  name               String // "Telegraph Commons"
  slug               String // URL slug within tenant site
  propertyType       PropertyType        @default(RESIDENTIAL)
  residentialSubtype ResidentialSubtype?
  commercialSubtype  CommercialSubtype?

  // Address
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  postalCode   String?
  country      String? @default("US")
  latitude     Float?
  longitude    Float?

  // AppFolio / backend linkage
  backendPlatform      BackendPlatform @default(NONE)
  backendPropertyId    String? // External ID in AppFolio etc.
  backendPropertyGroup String? // For AppFolio: propertyGroup name
  lastSyncedAt         DateTime?
  syncError            String?

  // Lifecycle — see PropertyLifecycle enum docs. Dashboards filter to
  // ACTIVE by default; new AppFolio-imported rows land as IMPORTED and
  // require operator promotion. EXCLUDED rows are sub-records (parking,
  // storage, etc.) we keep in the DB for audit but never count or show.
  lifecycle      PropertyLifecycle       @default(IMPORTED)
  lifecycleSetBy PropertyLifecycleSource @default(AUTO_CLASSIFIER)
  lifecycleSetAt DateTime?
  excludeReason  String?

  // Launch status — see PropertyLaunchStatus enum docs. Tracks the
  // per-property onboarding state independently of lifecycle. A
  // property must be lifecycle=ACTIVE AND launchStatus IN (LIVE,
  // ONBOARDING) to show in the marketing dashboards. Telegraph
  // Commons is LIVE; SG Real Estate's 121 other ACTIVE buildings
  // backfill to ONBOARDING and get promoted to LIVE individually as
  // each gets its site/pixel/GA4/GSC connected.
  launchStatus      PropertyLaunchStatus       @default(ONBOARDING)
  launchStatusSetBy PropertyLaunchStatusSource @default(AUTO)
  launchStatusSetAt DateTime?
  launchedAt        DateTime?

  // Marketing
  //
  // Image hierarchy on the avatar / detail header:
  //   1. heroImageUrl (operator-curated marketing hero, or scraped og:image)
  //   2. photoUrls[0]  (AppFolio-synced listing photo)
  //   3. Building icon fallback (PropertyAvatar renders this)
  //
  // websiteUrl + logoUrl + imageScrapeAt were added May 2026 to support
  // the auto-scrape workflow: if websiteUrl is set, we fetch the page and
  // extract og:image → heroImageUrl and og:logo / favicon → logoUrl. The
  // scrape result is cached via imageScrapeAt so we don't hammer the
  // origin on every page render. NULL imageScrapeAt = never scraped;
  // operators can also paste a heroImageUrl manually and it wins.
  websiteUrl           String? // Public marketing URL for this property
  logoUrl              String? // Property brand mark (scraped or uploaded)
  imageScrapeAt        DateTime?
  imageScrapeError     String?
  heroImageUrl         String?
  // Notion-style drag/zoom transform applied to the heroImageUrl when
  // rendered in PropertyHeroBanner. Offsets are in % of the image
  // container (translate); scale is a multiplier (1.0 = fit, max 3.0).
  // Defaults give the natural object-contain layout. Operator adjusts
  // via "Reposition" mode on the hero banner.
  heroImageOffsetX     Float     @default(0)
  heroImageOffsetY     Float     @default(0)
  heroImageScale       Float     @default(1)
  photoUrls            Json? // Array of URLs
  virtualTourUrl       String?
  googleReviewUrl      String? // Google Maps review link for this property
  googlePlaceId        String? // Google Places place_id, seeds the Reputation Scanner
  // Google aggregate rating cached from Places API. place.rating is averaged
  // across ALL reviews Google has (e.g. 4.0 across 49); place.userRatingCount
  // is the total count. These numbers drive the Reputation KPI tile; the 5
  // "most-helpful" individual reviews Places returns are persisted separately
  // as PropertyMention rows for the feed.
  googleAggRating      Float?
  googleAggReviewCount Int?
  googleAggUpdatedAt   DateTime?
  yelpBusinessId       String? // Yelp Fusion business id (alias or numeric id) for the Reputation Scanner
  redditSubreddits     Json? // Array of subreddit names (without "r/") to prioritize during reputation scans
  amenities            Json? // Array of strings
  yearBuilt            Int?
  totalUnits           Int?
  description          String?   @db.Text

  // Operator-editable attributes (Norman feedback, issue #68).
  // assetCategory is a short, asset-class-specific label
  // ("dorm-style", "apartment-style", "warehouse", "self-storage", …).
  // profileTags is a free-form tag array operators use to segment the
  // portfolio for the filter UI on /portal/properties (issue #54):
  // "affordable", "near campus", "downtown", "suburban", etc.
  // Asset class itself is derived from propertyType + subtype, and
  // size band is derived from totalUnits — see lib/properties/attrs.ts.
  assetCategory String?
  profileTags   String[] @default([])

  // SEO
  metaTitle       String?
  metaDescription String?

  // Pricing summary (denormalized for speed)
  priceMin       Int? // Cents
  priceMax       Int?
  availableCount Int? @default(0)

  listings             Listing[]
  leads                Lead[]
  tours                Tour[]
  applications         Application[]
  chatbotConversations ChatbotConversation[]
  visitors             Visitor[]
  creativeRequests     CreativeRequest[]
  adCampaigns          AdCampaign[]
  insights             Insight[]
  reputationScans      ReputationScan[]
  reputationMentions   PropertyMention[]
  adLibraryAdvertisers AdLibraryAdvertiser[]
  residents            Resident[]
  leases               Lease[]
  workOrders           WorkOrder[]
  clientReports        ClientReport[]
  popupCampaigns       PopupCampaign[]
  credentialEntries    CredentialEntry[]
  // Reverse relation for property-level RBAC. See UserPropertyAccess.
  userAccess           UserPropertyAccess[]
  // Per-property integration connections. NULL on these rows means
  // "applies to the whole org" (legacy / pre-migration behavior); a
  // populated propertyId scopes the connection to this single property
  // so multi-property tenants can wire each domain's GA4 + GSC + Pixel
  // independently.
  cursiveIntegrations  CursiveIntegration[]
  seoIntegrations      SeoIntegration[]
  websiteBuildRequests WebsiteBuildRequest[]
  aeoChecks            AeoCitationCheck[]
  neighborhoodPages    NeighborhoodPage[]
  // Per-property RentCast market intelligence snapshots (rent AVM,
  // market stats). Populated by the Market Intelligence section on
  // the property detail page; cached by lib/rentcast/cache.ts.
  rentCastSnapshots    RentCastSnapshot[]
  // SEO/AEO Agent backrefs — Phase 1
  seoActionRecs        SeoActionRecommendation[]
  contentDrafts        ContentDraft[]
  seoScoreHistory      SeoScoreHistory[]
  competitorScans      PropertyCompetitorScan[]
  // DataforSEO ingestion (Phase 1.5)
  seoTargetQueries     SeoTargetQuery[]
  seoScanJobs          SeoScanJob[]
  serpRankings         SerpRanking[]
  onPageAudits         OnPageAudit[]
  backlinkSummaries    BacklinkSummary[]
  // DataforSEO ingestion (Phase 2)
  onPageInstantAudits  OnPageInstantAudit[]
  localPackRankings    LocalPackRanking[]
  rankedKeywords       RankedKeyword[]
  keywordIntersections KeywordIntersection[]
  queryLandingDaily    QueryLandingDaily[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, slug])
  @@index([orgId])
  @@index([orgId, lifecycle])
  // Properties list page — supports the dominant query pattern after
  // the May 2026 pagination refactor: WHERE orgId + lifecycle ORDER BY
  // updatedAt DESC LIMIT/OFFSET. Without this Postgres has to sort the
  // (orgId,lifecycle)-filtered set at query time, which becomes the
  // bottleneck on portfolios approaching low thousands of properties.
  @@index([orgId, lifecycle, updatedAt(sort: Desc)])
  @@index([orgId, launchStatus])
  @@index([backendPlatform, backendPropertyId])
}

model Listing {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  // Backend sync
  backendListingId String? // External ID from AppFolio
  lastSyncedAt     DateTime?

  // Listing details
  unitType        String? // "Triple Shared", "XL Deluxe Single"
  unitNumber      String?
  bedrooms        Float?
  bathrooms       Float?
  squareFeet      Int?
  priceCents      Int?
  amenityFeeCents Int? // Norman's $85/mo amenity fee
  leaseTermMonths Int?

  isAvailable   Boolean   @default(true)
  availableFrom DateTime?
  availableTo   DateTime?

  photoUrls   Json?
  description String? @db.Text

  raw Json? // Raw payload from backend

  // AppFolio mirrors keyed off the unit
  residents  Resident[]
  leases     Lease[]
  workOrders WorkOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // DECISION: compound unique on (propertyId, backendListingId) added in
  // Sprint 06 so AppFolio sync can upsert in one query instead of the
  // PRD's awkward "findFirst then upsert by id" pattern. Nullable FK is fine
  // because Postgres permits nulls to be distinct under unique constraints.
  @@unique([propertyId, backendListingId])
  @@index([propertyId])
  @@index([propertyId, isAvailable])
}

// ============================================================================
// CRM: LEADS, TOURS, APPLICATIONS
// ============================================================================

model Lead {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  // Contact
  firstName String?
  lastName  String?
  email     String?
  phone     String?

  // Classification
  source       LeadSource
  sourceDetail String? // Campaign name, referrer URL, etc.
  status       LeadStatus @default(NEW)

  // Scoring
  score  Int     @default(0)
  intent String? // hot, warm, cold

  // Enrichment (from pixel or manual)
  enrichedData Json?

  // Preferences (for student housing: move-in date, budget, room type)
  desiredMoveIn     DateTime?
  budgetMinCents    Int?
  budgetMaxCents    Int?
  preferredUnitType String?
  notes             String?   @db.Text

  // External system idempotency keys. Populated when the Lead originated
  // from (or was matched to) an external record — AppFolio, Zapier, a
  // custom webhook. externalSystem is a string like "appfolio" and
  // externalId is the record's ID in that system. The compound unique
  // index at @@unique below makes re-syncs safe.
  externalSystem String?
  externalId     String?

  // Related visitor (if came from pixel)
  visitorId String?
  visitor   Visitor? @relation(fields: [visitorId], references: [id])

  // Conversation history
  conversations ChatbotConversation[]
  tours         Tour[]
  applications  Application[]
  residents     Resident[]

  // Ownership
  assignedToUserId String?

  firstSeenAt    DateTime  @default(now())
  lastActivityAt DateTime  @default(now())
  convertedAt    DateTime? // When they signed

  // Email cadence state, added Sprint 10
  unsubscribedFromEmails Boolean   @default(false)
  unsubscribedAt         DateTime?
  lastEmailSentAt        DateTime?
  nextScheduledEmailAt   DateTime?
  emailsSent             Int       @default(0)
  cadenceStage           String? // day_one_sent, day_three_sent, ...
  reviewRequestSentAt    DateTime? // When the review request email was sent

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, externalSystem, externalId])
  @@index([orgId, status])
  @@index([orgId, source])
  // Referrals + dashboard run 28-day groupBys by createdAt; no
  // existing index covers the date window.
  @@index([orgId, createdAt(sort: Desc)])
  @@index([email])
  @@index([cadenceStage])
  @@index([propertyId])
}

model Tour {
  id         String   @id @default(cuid())
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  status        TourStatus @default(REQUESTED)
  tourType      String? // in_person, virtual, self_guided
  scheduledAt   DateTime?
  completedAt   DateTime?
  attendeeCount Int?       @default(1)
  notes         String?    @db.Text

  // External system idempotency (e.g. AppFolio Showing Id).
  externalSystem String?
  externalId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([externalSystem, externalId])
  @@index([leadId])
  @@index([propertyId, status])
}

model Application {
  id         String   @id @default(cuid())
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  status    ApplicationStatus @default(STARTED)
  appliedAt DateTime?
  decidedAt DateTime?

  // Denorm of applicant data at time of application
  applicantData Json?

  // External linkage (e.g., AppFolio application ID)
  backendAppId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([propertyId, status])
}

// ============================================================================
// APPFOLIO MIRRORED ENTITIES — Residents, Leases, Work Orders
//
// AppFolio remains the source of truth for everything below. We mirror only
// what we need to surface in the operator dashboard (renewal pipeline,
// vacancy forecasting, property health). Every row carries `externalSystem`
// + `externalId` for idempotent upsert and `raw` JSON for the original
// payload so we can evolve our normalization without re-syncing.
// ============================================================================

enum ResidentStatus {
  ACTIVE
  PAST
  NOTICE_GIVEN
  EVICTED
  APPLICANT
}

model Resident {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  // Optional link to the listing (unit) the resident occupies. Nullable
  // because AppFolio rows occasionally lack the Unit join key.
  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  // Optional bridge to a Lead row when we can match by email.
  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  // Identity
  firstName String?
  lastName  String?
  email     String?
  phone     String?

  status ResidentStatus @default(ACTIVE)

  // Lease summary (denormalized so we can sort by lease end without
  // hopping). Kept in sync with the Lease row.
  currentLeaseId   String?   @unique
  currentLease     Lease?    @relation("CurrentLease", fields: [currentLeaseId], references: [id], onDelete: SetNull)
  unitNumber       String?
  moveInDate       DateTime?
  moveOutDate      DateTime?
  noticeGivenDate  DateTime?
  monthlyRentCents Int?

  externalSystem String? // "appfolio"
  externalId     String? // AppFolio occupancyId / tenantId

  raw Json?

  leases     Lease[]
  workOrders WorkOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, externalSystem, externalId])
  @@index([orgId, status])
  @@index([propertyId, status])
  // Residents page filters by orgId + status + propertyId together
  // (multi-property RBAC); composite covers all three.
  @@index([orgId, status, propertyId])
  @@index([email])
  @@index([moveOutDate])
}

enum LeaseStatus {
  PENDING
  ACTIVE
  EXPIRING
  RENEWED
  ENDED
  EVICTED
}

model Lease {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  residentId String?
  resident   Resident? @relation(fields: [residentId], references: [id], onDelete: SetNull)

  status LeaseStatus @default(ACTIVE)

  startDate            DateTime?
  endDate              DateTime?
  monthlyRentCents     Int?
  securityDepositCents Int?
  termMonths           Int?

  // Renewal / decision tracking — driven by AppFolio updates and
  // operator action.
  renewalSentAt   DateTime?
  renewalDecision String? // "accepted", "declined", "negotiating"
  noticeGivenAt   DateTime?

  // Delinquency snapshot (from delinquency report)
  currentBalanceCents Int?      @default(0)
  isPastDue           Boolean   @default(false)
  pastDueAsOf         DateTime?

  externalSystem String?
  externalId     String?

  raw Json?

  // Inverse relation back-pointer for Resident.currentLeaseId
  currentForResident Resident? @relation("CurrentLease")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, externalSystem, externalId])
  @@index([orgId, status])
  @@index([propertyId, status])
  // Renewals page filters lease.endDate within next 120d, scoped by
  // org. The single-column endDate index doesn't include orgId.
  @@index([orgId, endDate])
  @@index([endDate])
  @@index([isPastDue, currentBalanceCents])
}

enum WorkOrderStatus {
  NEW
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ON_HOLD
}

enum WorkOrderPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model WorkOrder {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  residentId String?
  resident   Resident? @relation(fields: [residentId], references: [id], onDelete: SetNull)

  // The AppFolio work order number ("WO-2024-1138")
  workOrderNumber String?

  status   WorkOrderStatus   @default(NEW)
  priority WorkOrderPriority @default(NORMAL)

  category    String? // "Plumbing", "HVAC", "Appliance", etc.
  title       String?
  description String? @db.Text
  unitNumber  String?

  vendorName  String?
  vendorEmail String?

  reportedAt   DateTime?
  scheduledFor DateTime?
  completedAt  DateTime?

  estimatedCostCents Int?
  actualCostCents    Int?

  externalSystem String?
  externalId     String?

  raw Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, externalSystem, externalId])
  @@index([orgId, status])
  @@index([propertyId, status, priority])
  @@index([reportedAt])
  @@index([completedAt])
}

// ============================================================================
// PIXEL / VISITORS
// ============================================================================

model Visitor {
  id         String       @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  propertyId String?
  property   Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  // Cursive identifier
  cursiveVisitorId String? @unique
  hashedEmail      String? // SHA-256 for ad platform sync
  visitorHash      String? // Unique ID for deduplication

  // Identified data
  status       VisitorIdentificationStatus @default(ANONYMOUS)
  firstName    String?
  lastName     String?
  email        String?
  phone        String?
  enrichedData Json? // Full Cursive enrichment payload

  // Session data
  firstSeenAt      DateTime @default(now())
  lastSeenAt       DateTime @default(now())
  sessionCount     Int      @default(1)
  pagesViewed      Json? // Array of URLs + timestamps
  totalTimeSeconds Int      @default(0)
  referrer         String?
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?

  // Intent score (computed)
  intentScore Int @default(0)

  // Lead conversion
  leads          Lead[]
  convertedAt    DateTime?
  outreachSent   Boolean   @default(false)
  outreachSentAt DateTime?

  // First-party pixel sessions and events
  sessions VisitorSession[]
  events   VisitorEvent[]

  // Operator-initiated chatbot engagements
  chatbotEngagements ChatbotEngagement[]

  // Ad platform sync state
  syncedToGoogleAds Boolean @default(false)
  syncedToMetaAds   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, status])
  @@index([orgId, lastSeenAt])
  @@index([orgId, email])
  @@index([cursiveVisitorId])
  @@index([hashedEmail])
  // Visitors page "Hot" tab filters by intentScore; without these
  // composite indexes the query would full-scan the org.
  @@index([orgId, intentScore(sort: Desc)])
  @@index([orgId, intentScore(sort: Desc), lastSeenAt(sort: Desc)])
}

model CursiveIntegration {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Per-property scoping. NULL = legacy "applies to whole org" — every
  // existing row at the time of the multi-property migration is NULL,
  // which preserves the prior single-pixel-per-org behavior. New
  // connections always specify a property so multi-property tenants
  // (e.g. SG Real Estate's 71 properties) can run a distinct pixel per
  // domain.
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  cursivePixelId    String? // The Cursive pixel ID provisioned for this tenant
  cursiveAccountId  String? // Cursive account this pixel belongs to
  pixelScriptUrl    String? // CDN URL for the pixel script
  installedOnDomain String? // Which hostname the pixel is installed on
  provisionedAt     DateTime?
  lastEventAt       DateTime?
  totalEventsCount  Int       @default(0)

  // Per-tenant webhook token. URL-as-secret so AL's per-pixel webhook UI
  // works without our shared header. 32 hex chars = 128 bits of entropy.
  webhookToken String? @unique

  // AudienceLab segment binding for the admin "Sync from segment" pull
  cursiveSegmentId  String?
  lastSegmentSyncAt DateTime?

  // Weekly digest delivery preferences
  weeklyDigestEnabled Boolean @default(true)
  weeklyDigestEmails  Json? // Array of emails

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Composite uniqueness allows ONE row per (org, property), with the
  // legacy "all properties" row keyed as (orgId, NULL). Postgres treats
  // NULL as distinct in unique indexes by default, so the prior
  // org-wide row coexists with new per-property rows without conflict.
  @@unique([orgId, propertyId])
  @@index([orgId])
  @@index([propertyId])
}

// AudienceLab does not expose a programmatic pixel-creation API, so when a
// tenant asks for visitor identification we queue a request here. Ops sets
// up the pixel + segment + workflow in the AL UI, then pastes the resulting
// pixel_id into the admin Cursive panel — which marks the matching request
// FULFILLED and emails the customer with their install snippet.
enum PixelRequestStatus {
  PENDING
  FULFILLED
  CANCELLED
}

model PixelProvisionRequest {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  websiteName String
  websiteUrl  String

  status            PixelRequestStatus @default(PENDING)
  requestedByUserId String?
  requestedAt       DateTime           @default(now())
  fulfilledAt       DateTime?

  // Snapshot of the resulting pixel_id once fulfilled (for audit/debugging).
  fulfilledPixelId String?
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, status])
  @@index([status, requestedAt])
}

// ============================================================================
// FIRST-PARTY PIXEL — sessions + events from our own JS snippet
// ============================================================================
// `Visitor` is the long-lived person record (potentially identified). Each
// browser cookie maps to one or more `VisitorSession`s, and each pageview /
// scroll / time-on-page tick is a `VisitorEvent`. Keeping this in two tables
// stays close to the Segment / PostHog model and keeps Visitor lean.

model VisitorSession {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  visitorId String?
  visitor   Visitor?     @relation(fields: [visitorId], references: [id], onDelete: SetNull)

  // Cookie / device identifiers (set by our pixel)
  anonymousId  String // cookie value, lives in browser
  sessionToken String  @unique // server-issued per session
  deviceHash   String? // sha256(ua + ip) — helps cross-browser dedupe

  // Acquisition
  firstUrl      String?
  firstReferrer String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmTerm       String?
  utmContent    String?

  // Device
  userAgent String?
  ipAddress String?
  country   String?
  language  String?

  // Engagement aggregate (denormalised so the feed page reads in one query)
  pageviewCount    Int @default(0)
  totalTimeSeconds Int @default(0)
  maxScrollDepth   Int @default(0) // 0–100 percentage

  startedAt   DateTime  @default(now())
  lastEventAt DateTime  @default(now())
  endedAt     DateTime?

  events VisitorEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, startedAt])
  @@index([orgId, anonymousId])
  @@index([visitorId])
}

model VisitorEvent {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  sessionId String
  session   VisitorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  visitorId String?
  visitor   Visitor?       @relation(fields: [visitorId], references: [id], onDelete: SetNull)

  type     String // "pageview" | "identify" | "scroll" | "timing" | "click" | "form_submit" | "unload"
  url      String?
  path     String?
  title    String?
  referrer String?

  // Optional payloads (JSON to stay flexible without exploding the schema)
  properties        Json?
  scrollDepth       Int? // 0–100
  timeOnPageSeconds Int?

  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([orgId, occurredAt])
  @@index([sessionId])
  @@index([visitorId])
  @@index([type])
}

// ============================================================================
// CHATBOT
// ============================================================================

model ChatbotConversation {
  id         String       @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  propertyId String?
  property   Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  leadId     String?
  lead       Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)

  status      ChatbotConversationStatus @default(ACTIVE)
  // DECISION: sessionId needs @unique so the chatbot API can upsert on it
  // in one query. Added in Sprint 09.
  sessionId   String                    @unique // Browser session identifier
  visitorHash String? // Link back to Visitor if identified

  // Messages stored as JSON array of {role, content, timestamp}
  messages Json

  // Captured data
  capturedName  String?
  capturedEmail String?
  capturedPhone String?

  // Engagement
  messageCount  Int       @default(0)
  lastMessageAt DateTime  @default(now())
  handedOffAt   DateTime?
  handoffReason String?

  // Metadata
  userAgent String?
  ipAddress String?
  pageUrl   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  flags ConversationFlag[]

  @@index([orgId, status])
  @@index([orgId, lastMessageAt])
  // /portal/conversations filters by status AND orders by
  // lastMessageAt — the split indexes above don't cover both at once.
  @@index([orgId, status, lastMessageAt(sort: Desc)])
  @@index([leadId])
  @@index([propertyId])
  @@index([sessionId])
}

// Operator -> live visitor outbound message. The widget polls
// /api/public/chatbot/inbox for PENDING rows scoped to its sessionId and
// renders them as assistant turns. triggeredById stores the Clerk userId
// (intentionally not a FK so the row outlives operator account deletions).
model ChatbotEngagement {
  id            String           @id @default(cuid())
  orgId         String
  org           Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  visitorId     String?
  visitor       Visitor?         @relation(fields: [visitorId], references: [id], onDelete: SetNull)
  sessionId     String
  triggeredById String
  message       String           @db.Text
  openWidget    Boolean          @default(true)
  status        EngagementStatus @default(PENDING)
  deliveredAt   DateTime?
  repliedAt     DateTime?
  createdAt     DateTime         @default(now())

  @@index([sessionId])
  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@index([visitorId])
}

// ============================================================================
// CREATIVE STUDIO
