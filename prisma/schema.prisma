// ---------------------------------------------------------------------------
// SiteIntelligence — cached site context per org.
//
// Populated by lib/intelligence/site-ingest.ts on org setup + nightly cron.
// Powers the content drafter's "this AI knows your brand" feel:
//
//   * Firecrawl /crawl on the org's primary domain — collects up to 50
//     pages, persists their markdown + URL list.
//   * Firecrawl /scrape on the homepage + a handful of cornerstone pages
//     for deeper content excerpts.
//   * Perplexity Sonar research on the company — competitive landscape,
//     voice cues, positioning lifted from the open web.
//   * Brand voice notes extracted by Claude from the crawled copy
//     (tone, register, dos/don'ts).
//
// Everything stuffs into the assistant's system prompt at draft time so
// the AI proposes ideas grounded in the actual brand, not generic
// real-estate boilerplate.
// ---------------------------------------------------------------------------
model SiteIntelligence {
  id         String       @id @default(cuid())
  orgId      String       @unique
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  /// Canonical URL the ingest was run against. Usually
  /// `https://<primary-domain>`.
  rootUrl    String?

  /// Sitemap URLs discovered during crawl. Capped at 500 entries —
  /// anything beyond is sampled.
  sitemapUrls String[]

  /// Up to 50 crawled pages with { url, title, description, markdown,
  /// h1, h2[], wordCount }. Schema kept loose in JSON so we don't have
  /// to migrate every time Firecrawl tweaks their response shape.
  pages       Json?

  /// Perplexity Sonar research blob. Keys: companyOverview,
  /// competitiveLandscape, recentNews, positioningCues.
  research    Json?

  /// Claude-extracted brand voice notes — tone, register, taboo words,
  /// preferred CTAs. Rendered into the system prompt verbatim.
  brandVoice  String? @db.Text

  /// Timestamps split so we can refresh research more often than crawl.
  crawledAt   DateTime?
  researchedAt DateTime?
  brandVoiceAt DateTime?

  /// Last ingest run summary (URLs crawled, pages scraped, cost USD).
  lastRunStats Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

