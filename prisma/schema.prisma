// ============================================================================
// SEO/AEO Phase 2 — extended ingestion + unified fact table
//
// What this adds:
//
//   OnPageInstantAudit       Per-URL on-page audit (titles, meta, H1s, schema,
//                            broken links, image alts). Beyond Lighthouse.
//   LocalPackRanking         Google local pack position per (query, day).
//                            The huge missing piece for apartment marketing.
//   RankedKeyword            Every keyword OUR domain ranks for (DataforSEO
//                            Labs ranked_keywords). Drives portfolio charts.
//   KeywordIntersection      Per (our domain × competitor) — queries the
//                            competitor outranks us on. Pure content-gap.
//   QueryLandingDaily        Unified (date, url, query) fact table joining
//                            DataforSEO + GSC + GA4. Backbone of every
//                            composite chart.
// ============================================================================

model OnPageInstantAudit {
  id         String       @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
