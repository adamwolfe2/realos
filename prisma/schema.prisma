// ----------------------------------------------------------------------------
// Unified fact table — the backbone of every composite chart.
//
// One row per (org, propertyId, date, url, query). Nightly aggregator stitches
// DataforSEO SerpRanking + GSC SeoQuery + GA4 page metrics into a single
// dimensionally-conformed row so every cross-source chart is a single
// Prisma query away.
// ----------------------------------------------------------------------------
model QueryLandingDaily {
  id         String       @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  propertyId String?
  property   Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)

