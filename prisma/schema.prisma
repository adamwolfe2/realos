// ============================================================================
// SEO/AEO Agent — DataforSEO ingestion layer (Phase 1.5)
//
// These models cache live DataforSEO results per property so the SEO Agent
// can synthesize recommendations from real ranking + audit + backlink data
// without round-tripping the API on every page load.
//
// Daily ingestion: /api/cron/dataforseo-sync (04:00 UTC)
// Cost guard: per property capped at 4 target queries × 1 SERP call
// + 1 lighthouse + 1 backlinks summary = ~$0.05/property/day. At 50 LIVE
// properties = ~$2.50/day = ~$75/mo across the platform.
// ============================================================================

model SeoTargetQuery {
  id         String       @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  propertyId String?
  property   Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  /// The target search query operator wants to track / rank for.
  query        String  @db.Text
  /// Loose tag — "transactional", "local", "informational", "branded".
  intent       String?
  /// DataforSEO numeric location code (default 2840 = United States).
  locationCode Int?
  /// `null` = derived automatically at first scan; set to a user id
  /// when the operator added the query manually.
  addedBy      String?
  active       Boolean @default(true)

  rankings SerpRanking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, propertyId, query])
  @@index([orgId, propertyId, active])
}

// ---------------------------------------------------------------------------
// SeoScanJob — async scan queue.
//
// DataforSEO scans chain 10 API calls per property (SERP × N queries +
// Lighthouse + backlinks + competitors + on-page + intent + ranked KWs +
// intersection + local pack). Lighthouse alone often takes 30–40s, well
// past Vercel's 60s synchronous-route ceiling.
//
// Flow:
//   1. Operator clicks "Re-scan now" → POST /api/portal/seo/scan/[id]
//      inserts a QUEUED row and returns 202 with { jobId } immediately.
//   2. /api/cron/seo-scan-worker (every minute) atomically claims the
//      oldest QUEUED row via updateMany(where: { status: QUEUED, id })
//      → updates to RUNNING + startedAt, then runs the orchestrator
//      stage-by-stage, persisting `progressStage` between calls.
//   3. UI polls /api/portal/seo/scan/[id]/status which now joins the
//      latest SeoScanJob row and renders "Querying competitors… (4/10)".
//   4. A reaper (same worker route) flips RUNNING rows older than 10
//      minutes back to QUEUED with attempts++ so stuck jobs recover.
// ---------------------------------------------------------------------------
model SeoScanJob {
  id         String        @id @default(cuid())
  orgId      String
  org        Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  status         SeoScanJobStatus @default(QUEUED)
  /// Human-readable label of the current stage ("SERP rankings",
  /// "Lighthouse audit", "Backlinks summary", etc). Drives the
  /// "Querying X…" line in the operator UI.
  progressStage  String?
  /// 0-100 progress estimate. Worker bumps this after each completed
  /// stage so a property with 10 stages ticks up 10pp per call.
  progressPct    Int              @default(0)
  /// Final orchestrator stats blob (serpQueriesScanned, lighthouseAudits,
  /// errors[], costEstimateUsd). Populated when status flips to DONE/FAILED.
  result         Json?
  /// Fatal error message if the orchestrator threw uncaught. Per-stage
  /// errors are inside `result.errors` instead.
  error          String?          @db.Text
  /// Tracks worker retries — incremented every time the reaper flips a
  /// stuck RUNNING row back to QUEUED. Stops retrying past 3.
  attempts       Int              @default(0)

  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([orgId, status])
  @@index([propertyId, createdAt])
  @@index([status, createdAt])
}

enum SeoScanJobStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

