// ============================================================================
// 00-schema.prisma — Complete database schema for {{PRODUCT_NAME}}
// ============================================================================
// Initialize with: pnpm db:push
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

// DECISION: Prisma 7 moved connection URLs out of the schema into
// prisma.config.ts. DATABASE_URL and DIRECT_DATABASE_URL are read there.
// Standard Prisma 7 configuration. The PRD schema is kept
// otherwise byte-identical.
datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum OrgType {
  AGENCY // Singleton: us
  CLIENT // Each real estate company
}

// Which product surface an org uses. STUDENT_HOUSING is the original
// LeaseStack offering (sites, chatbot, AppFolio, marketing OS).
// AUDIENCE_SYNC is the residential/commercial product: AL segments piped
// to ad accounts and CRMs. AGENCY_INTERNAL is reserved for our own org.
enum ProductLine {
  STUDENT_HOUSING
  AUDIENCE_SYNC
  AGENCY_INTERNAL
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  MIXED
}

// Property lifecycle. Separates "AppFolio dumped this row into the DB"
// from "operator confirmed this is a marketable building." Dashboards,
// sidebars, count tiles, onboarding progress, and demo-readiness all
// filter to ACTIVE only by default. EXCLUDED rows stay in the database
// for audit/dedup but never count or display unless the operator opens
// the curation queue. See lib/properties/marketable.ts for the canonical
// where-clause helper used by every count site.
enum PropertyLifecycle {
  IMPORTED // Fresh from AppFolio sync, awaiting operator review
  ACTIVE // Marketable building under LeaseStack management
  EXCLUDED // Parking lot / storage / sub-record / placeholder
  ARCHIVED // Was active, no longer on the platform
}

// Whether the lifecycle was set by the auto-classifier (which AppFolio
// re-syncs may revisit) or explicitly by an operator (sticky — re-syncs
// must not overwrite).
enum PropertyLifecycleSource {
  AUTO_CLASSIFIER
  OPERATOR
}

// Property launch status. Separate concept from PropertyLifecycle:
//   lifecycle  = "Should this Property row count at all?" (admin-level
//                AppFolio curation: parking/storage/sub-record vs real
//                building.)
//   launchStatus = "Is this real building actually live with marketing
//                data flowing?" (operator-level onboarding: site built,
//                pixel installed, GA4/GSC connected, ads live.)
//
// Dashboards key off launchStatus = LIVE for "show real metrics."
// ONBOARDING = visible in the operator's queue with a checklist.
// DRAFT = approved but no integrations connected; counted but quiet.
// PAUSED = operator paused; keep row, suspend reporting.
enum PropertyLaunchStatus {
  DRAFT
  ONBOARDING
  LIVE
  PAUSED
}

// Whether launch status came from the auto-recompute (which checks
// pixel/integration freshness) or from an operator override (sticky).
enum PropertyLaunchStatusSource {
  AUTO
  OPERATOR
}

enum ResidentialSubtype {
  STUDENT_HOUSING
  MULTIFAMILY
  SENIOR_LIVING
  SINGLE_FAMILY_RENTAL
  CO_LIVING
  SHORT_TERM_RENTAL
