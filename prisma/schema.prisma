// ============================================================================
// 00-schema.prisma — Complete database schema for {{PRODUCT_NAME}}
// ============================================================================
// Initialize with: pnpm db:push
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

// DECISION: Prisma 7 moved connection URLs out of the schema into
// prisma.config.ts. DATABASE_URL and DIRECT_DATABASE_URL are read there.
// Standard Prisma 7 configuration. The PRD schema is kept
// otherwise byte-identical.
datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum OrgType {
  AGENCY // Singleton: us
  CLIENT // Each real estate company
}

// Which product surface an org uses. STUDENT_HOUSING is the original
// LeaseStack offering (sites, chatbot, AppFolio, marketing OS).
// AUDIENCE_SYNC is the residential/commercial product: AL segments piped
// to ad accounts and CRMs. AGENCY_INTERNAL is reserved for our own org.
enum ProductLine {
  STUDENT_HOUSING
  AUDIENCE_SYNC
  AGENCY_INTERNAL
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  MIXED
}

enum ResidentialSubtype {
  STUDENT_HOUSING
  MULTIFAMILY
  SENIOR_LIVING
  SINGLE_FAMILY_RENTAL
  CO_LIVING
  SHORT_TERM_RENTAL
}

enum CommercialSubtype {
  OFFICE
  RETAIL
  INDUSTRIAL
  MIXED_USE
  FLEX_SPACE
  MEDICAL_OFFICE
}

enum BackendPlatform {
  APPFOLIO
  YARDI_BREEZE
  YARDI_VOYAGER
  BUILDIUM
  RENTMANAGER
  ENTRATA
  REALPAGE
  PROPERTYWARE
  MRI
  VTS
  OTHER
  NONE
}

enum UserRole {
  AGENCY_OWNER // Adam
  AGENCY_ADMIN // Agency team member
  AGENCY_OPERATOR // Limited agency role
  CLIENT_OWNER // Primary client contact
  CLIENT_ADMIN // Client team member with full portal access
  CLIENT_VIEWER // Read-only client access
  LEASING_AGENT // Specific role on client team
  AL_PARTNER // AudienceLab partner with cross-org visibility on AUDIENCE_SYNC orgs
}

enum TenantStatus {
  INTAKE_RECEIVED
  CONSULTATION_BOOKED
  PROPOSAL_SENT
  CONTRACT_SIGNED
  BUILD_IN_PROGRESS
  QA
  LAUNCHED
  ACTIVE
  AT_RISK
  CHURNED
  PAUSED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum LeadStatus {
  NEW
  CONTACTED
  TOUR_SCHEDULED
  TOURED
  APPLICATION_SENT
  APPLIED
  APPROVED
  SIGNED
  LOST
  UNQUALIFIED
}

enum LeadSource {
  CHATBOT
  FORM
  PIXEL_OUTREACH
  REFERRAL
  GOOGLE_ADS
  META_ADS
  ORGANIC
  DIRECT
  EMAIL_CAMPAIGN
  COLD_EMAIL
  MANUAL
  OTHER
}

enum TourStatus {
  REQUESTED
  SCHEDULED
  COMPLETED
  NO_SHOW
  CANCELLED
}

enum ApplicationStatus {
  STARTED
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  DENIED
  WITHDRAWN
}

enum VisitorIdentificationStatus {
  ANONYMOUS
  IDENTIFIED
  ENRICHED
  MATCHED_TO_LEAD
}

enum ChatbotConversationStatus {
  ACTIVE
  ABANDONED
  LEAD_CAPTURED
  HANDED_OFF
  CLOSED
}

enum ChatbotCaptureMode {
  PRE_CHAT
  ON_INTENT
  OFF
}

enum EngagementStatus {
  PENDING
  DELIVERED
  DISMISSED
  REPLIED
}

enum CreativeRequestStatus {
  SUBMITTED
  IN_REVIEW
  IN_PROGRESS
  REVISION_REQUESTED
  DELIVERED
  APPROVED
  REJECTED
}

enum CreativeFormat {
  INSTAGRAM_STORY
  INSTAGRAM_FEED
  FACEBOOK_FEED
  GOOGLE_DISPLAY
  GOOGLE_SEARCH_COPY
  EMAIL_HEADER
  WEB_BANNER
  PRINT_FLYER
  OTHER
}

enum AdPlatform {
  GOOGLE_ADS
  META
  LINKEDIN
  TIKTOK
  REDDIT
}

enum SubscriptionTier {
  STARTER
  GROWTH
  SCALE
  CUSTOM
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
}

enum NoteType {
  GENERAL
  LEAD_INTERACTION
  BUILD
  BILLING
  QA
  SUPPORT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  IMPERSONATE_START
  IMPERSONATE_END
  LOGIN
  EXPORT
  SETTING_CHANGE
}

// ============================================================================
// CORE TENANCY
// ============================================================================

model Organization {
  id               String      @id @default(cuid())
  name             String
  shortName        String?
  slug             String      @unique // {slug}.platformdomain.com
  orgType          OrgType     @default(CLIENT)
  productLine      ProductLine @default(STUDENT_HOUSING)
  clerkOrgId       String?     @unique
  stripeCustomerId String?     @unique

  // Optional override for AL credentials when an AUDIENCE_SYNC org wants to
  // use their own AudienceLab account instead of the platform-shared key.
  cursiveApiKeyOverride String?

  // Property classification
  propertyType       PropertyType        @default(RESIDENTIAL)
  residentialSubtype ResidentialSubtype?
  commercialSubtype  CommercialSubtype?

  // Tenant status
  status       TenantStatus @default(INTAKE_RECEIVED)
  launchedAt   DateTime?
  atRiskReason String?

  // Branding (for tenant marketing site + portal)
  logoUrl        String?
  primaryColor   String? @default("#000000")
  secondaryColor String?
  brandFont      String?

  // Contact
  primaryContactName  String?
  primaryContactEmail String?
  primaryContactPhone String?
  primaryContactRole  String?

  // Location (company HQ, not properties)
  hqAddressLine1 String?
  hqCity         String?
  hqState        String?
  hqPostalCode   String?

  // Subscription
  subscriptionTier      SubscriptionTier?
  subscriptionStatus    SubscriptionStatus?
  subscriptionStartedAt DateTime?
  mrrCents              Int?                @default(0)
  buildFeePaidCents     Int?                @default(0)
  adSpendMarkupPct      Float?              @default(0.15) // 15% default

  // Selected modules (a la carte flags)
  moduleWebsite        Boolean @default(true)
  modulePixel          Boolean @default(false)
  moduleChatbot        Boolean @default(false)
  moduleGoogleAds      Boolean @default(false)
  moduleMetaAds        Boolean @default(false)
  moduleSEO            Boolean @default(false)
  moduleEmail          Boolean @default(false)
  moduleOutboundEmail  Boolean @default(false)
  moduleReferrals      Boolean @default(false)
  moduleCreativeStudio Boolean @default(false)
  moduleLeadCapture    Boolean @default(true)

  // Site hosting mode
  bringYourOwnSite Boolean @default(false)

  // Relationships
  users                  User[]
  properties             Property[]
  domains                DomainBinding[]
  tenantSiteConfig       TenantSiteConfig?
  leads                  Lead[]
  visitors               Visitor[]
  chatbotConversations   ChatbotConversation[]
  creativeRequests       CreativeRequest[]
  adAccounts             AdAccount[]
  adCampaigns            AdCampaign[]
  emailSubscribers       EmailSubscriber[]
  intakeSubmission       IntakeSubmission?
  projects               Project[]
  auditEvents            AuditEvent[]
  clientNotes            ClientNote[]
  cursiveIntegration     CursiveIntegration?
  pixelProvisionRequests PixelProvisionRequest[]
  appfolioIntegration    AppFolioIntegration?
  seoIntegrations        SeoIntegration[]
  seoSnapshots           SeoSnapshot[]
  seoQueries             SeoQuery[]
  seoLandingPages        SeoLandingPage[]
  addresses              Address[]
  apiKeys                ApiKey[]
  integrationRequests    IntegrationRequest[]
  visitorSessions        VisitorSession[]
  visitorEvents          VisitorEvent[]
  chatbotEngagements     ChatbotEngagement[]
  notifications          Notification[]
  insights               Insight[]
  clientReports          ClientReport[]
  conversationFlags      ConversationFlag[]
  reputationScans        ReputationScan[]
  reputationMentions     PropertyMention[]
  adLibraryAdvertisers   AdLibraryAdvertiser[]
  audienceSegments       AudienceSegment[]
  audienceDestinations   AudienceDestination[]
  audienceSyncRuns       AudienceSyncRun[]
  audienceSchedules      AudienceSyncSchedule[]
  residents              Resident[]
  leases                 Lease[]
  workOrders             WorkOrder[]

  // Onboarding checklist dismissed by the operator. When false, the
  // first-login walkthrough renders on /portal.
  onboardingDismissed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgType, status])
  @@index([slug])
  @@index([clerkOrgId])
}

model User {
  id          String  @id @default(cuid())
  clerkUserId String  @unique
  email       String  @unique
  firstName   String?
  lastName    String?
  phone       String?
  avatarUrl   String?

  role  UserRole     @default(CLIENT_VIEWER)
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  auditEvents   AuditEvent[]
  tasksAssigned ProjectTask[]  @relation("TaskAssignee")
  notifications Notification[]

  // Per-property access grants. ZERO rows = unrestricted (org-wide
  // access — preserves the legacy behavior so existing users aren't
  // affected by the property-RBAC rollout). ONE OR MORE rows = the
  // user can ONLY see those properties' data on every portal page.
  propertyAccess UserPropertyAccess[]

  // Command Center: last time this operator opened the briefing view. Used to
  // compute "what's new since you last looked" deltas on /portal/briefing.
  lastBriefingViewedAt DateTime?

  @@index([orgId])
  @@index([role])
}

// ---------------------------------------------------------------------------
// UserPropertyAccess — fine-grained gate for "this user can only see
// these properties." Sits alongside the org-level User.orgId gate; both
// are enforced. Designed so:
//   - 0 rows for a user => unrestricted (org-wide). Default for every
//     existing user, so this migration ships without breaking anyone.
//   - 1+ rows => restricted. The user's view is locked to those property
//     ids on every page (pages also filter their property dropdown to
//     show only the allowed options).
//
// Property-level role override (`role`) is reserved for a future PR
// where, e.g., a Telegraph Commons leasing agent might be a
// CLIENT_ADMIN on Telegraph but a CLIENT_VIEWER on a sister property.
// Not used at gate time today.
// ---------------------------------------------------------------------------
model UserPropertyAccess {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  // Optional per-property role override. NULL = inherit User.role.
  role UserRole?

  // Audit trail: who granted this access + when.
  grantedBy String?
  grantedAt DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

model ApiKey {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  name      String // operator-chosen label, e.g. "Zapier production"
  keyPrefix String // first ~12 chars of the raw key, for display only (re_live_aB12...)
  keyHash   String   @unique // SHA-256 of the full raw key; the raw key is never stored
  scopes    String[] // e.g. ["ingest:lead", "ingest:visitor", "ingest:tour", "ingest:chatbot"] or ["*"]

  // Expiration / rotation. expiresAt is optional ("never" = null). The
  // auth check rejects keys past this timestamp the same way it rejects
  // revokedAt. rotatedFromKeyId is a forward-only foreign key (no back
  // reference needed; queries that want the chain do an explicit
  // findMany on rotatedFromKeyId). (audit BUG #5)
  expiresAt        DateTime?
  rotatedFromKeyId String?

  createdByUserId String?
  lastUsedAt      DateTime?
  lastUsedIp      String?
  usageCount      Int       @default(0)
  revokedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([keyHash])
  @@index([expiresAt])
}

model DomainBinding {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  hostname       String  @unique // telegraphcommons.com
  isPrimary      Boolean @default(false)
  vercelDomainId String?
  sslStatus      String? // pending, active, failed
  dnsConfigured  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

model TenantSiteConfig {
  id    String       @id @default(cuid())
  orgId String       @unique
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Site content
  siteTitle       String?
  tagline         String?
  heroHeadline    String?
  heroSubheadline String?
  heroImageUrl    String?
  aboutCopy       String? @db.Text

  // CTA config
  primaryCtaText String? @default("Apply Now")
  primaryCtaUrl  String?
  phoneNumber    String?
  contactEmail   String?

  // SEO
  metaTitle       String?
  metaDescription String?
  ogImageUrl      String?

  // Feature toggles (site-level)
  showListings     Boolean @default(true)
  showFloorPlans   Boolean @default(true)
  showAmenities    Boolean @default(true)
  showReviews      Boolean @default(false)
  showBlog         Boolean @default(false)
  enableExitIntent Boolean @default(true)
  enableChatbot    Boolean @default(false)
  enablePixel      Boolean @default(false)

  // Chatbot config
  chatbotEnabled            Boolean            @default(false)
  chatbotAvatarUrl          String?
  chatbotPersonaName        String?
  chatbotGreeting           String?
  chatbotTeaserText         String?
  chatbotBrandColor         String?
  chatbotCaptureMode        ChatbotCaptureMode @default(ON_INTENT)
  chatbotKnowledgeBase      String?            @db.Text
  chatbotIdleTriggerSeconds Int                @default(5)

  // Tenant analytics. When ga4MeasurementId is set, the embed widget will
  // lazy-load gtag.js with that ID on the host page if no dataLayer/gtag is
  // already present, then fire chatbot_opened / chatbot_lead_captured events
  // directly into the tenant's GA4 property. Bypasses GTM entirely.
  ga4MeasurementId    String?
  exitIntentHeadline  String?
  exitIntentBody      String?
  exitIntentCtaText   String?
  exitIntentOfferCode String?

  // Raw JSON for extensibility
  customJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// REAL ESTATE ENTITIES
// ============================================================================

model Property {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  name               String // "Telegraph Commons"
  slug               String // URL slug within tenant site
  propertyType       PropertyType        @default(RESIDENTIAL)
  residentialSubtype ResidentialSubtype?
  commercialSubtype  CommercialSubtype?

  // Address
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  postalCode   String?
  country      String? @default("US")
  latitude     Float?
  longitude    Float?

  // AppFolio / backend linkage
  backendPlatform      BackendPlatform @default(NONE)
  backendPropertyId    String? // External ID in AppFolio etc.
  backendPropertyGroup String? // For AppFolio: propertyGroup name
  lastSyncedAt         DateTime?
  syncError            String?

  // Marketing
  heroImageUrl         String?
  photoUrls            Json? // Array of URLs
  virtualTourUrl       String?
  googleReviewUrl      String? // Google Maps review link for this property
  googlePlaceId        String? // Google Places place_id, seeds the Reputation Scanner
  // Google aggregate rating cached from Places API. place.rating is averaged
  // across ALL reviews Google has (e.g. 4.0 across 49); place.userRatingCount
  // is the total count. These numbers drive the Reputation KPI tile; the 5
  // "most-helpful" individual reviews Places returns are persisted separately
  // as PropertyMention rows for the feed.
  googleAggRating      Float?
  googleAggReviewCount Int?
  googleAggUpdatedAt   DateTime?
  yelpBusinessId       String? // Yelp Fusion business id (alias or numeric id) for the Reputation Scanner
  redditSubreddits     Json? // Array of subreddit names (without "r/") to prioritize during reputation scans
  amenities            Json? // Array of strings
  yearBuilt            Int?
  totalUnits           Int?
  description          String?   @db.Text

  // SEO
  metaTitle       String?
  metaDescription String?

  // Pricing summary (denormalized for speed)
  priceMin       Int? // Cents
  priceMax       Int?
  availableCount Int? @default(0)

  listings             Listing[]
  leads                Lead[]
  tours                Tour[]
  applications         Application[]
  chatbotConversations ChatbotConversation[]
  visitors             Visitor[]
  creativeRequests     CreativeRequest[]
  adCampaigns          AdCampaign[]
  insights             Insight[]
  reputationScans      ReputationScan[]
  reputationMentions   PropertyMention[]
  adLibraryAdvertisers AdLibraryAdvertiser[]
  residents            Resident[]
  leases               Lease[]
  workOrders           WorkOrder[]
  clientReports        ClientReport[]
  // Reverse relation for property-level RBAC. See UserPropertyAccess.
  userAccess           UserPropertyAccess[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, slug])
  @@index([orgId])
  @@index([backendPlatform, backendPropertyId])
}

model Listing {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  // Backend sync
  backendListingId String? // External ID from AppFolio
  lastSyncedAt     DateTime?

  // Listing details
  unitType        String? // "Triple Shared", "XL Deluxe Single"
  unitNumber      String?
  bedrooms        Float?
  bathrooms       Float?
  squareFeet      Int?
  priceCents      Int?
  amenityFeeCents Int? // Norman's $85/mo amenity fee
  leaseTermMonths Int?

  isAvailable   Boolean   @default(true)
  availableFrom DateTime?
  availableTo   DateTime?

  photoUrls   Json?
  description String? @db.Text

  raw Json? // Raw payload from backend

  // AppFolio mirrors keyed off the unit
  residents  Resident[]
  leases     Lease[]
  workOrders WorkOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // DECISION: compound unique on (propertyId, backendListingId) added in
  // Sprint 06 so AppFolio sync can upsert in one query instead of the
  // PRD's awkward "findFirst then upsert by id" pattern. Nullable FK is fine
  // because Postgres permits nulls to be distinct under unique constraints.
  @@unique([propertyId, backendListingId])
  @@index([propertyId])
  @@index([propertyId, isAvailable])
}

// ============================================================================
// CRM: LEADS, TOURS, APPLICATIONS
// ============================================================================

model Lead {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  // Contact
  firstName String?
  lastName  String?
  email     String?
  phone     String?

  // Classification
  source       LeadSource
  sourceDetail String? // Campaign name, referrer URL, etc.
  status       LeadStatus @default(NEW)

  // Scoring
  score  Int     @default(0)
  intent String? // hot, warm, cold

  // Enrichment (from pixel or manual)
  enrichedData Json?

  // Preferences (for student housing: move-in date, budget, room type)
  desiredMoveIn     DateTime?
  budgetMinCents    Int?
  budgetMaxCents    Int?
  preferredUnitType String?
  notes             String?   @db.Text

  // External system idempotency keys. Populated when the Lead originated
  // from (or was matched to) an external record — AppFolio, Zapier, a
  // custom webhook. externalSystem is a string like "appfolio" and
  // externalId is the record's ID in that system. The compound unique
  // index at @@unique below makes re-syncs safe.
  externalSystem String?
  externalId     String?

  // Related visitor (if came from pixel)
  visitorId String?
  visitor   Visitor? @relation(fields: [visitorId], references: [id])

  // Conversation history
  conversations ChatbotConversation[]
  tours         Tour[]
  applications  Application[]
  residents     Resident[]

  // Ownership
  assignedToUserId String?

  firstSeenAt    DateTime  @default(now())
  lastActivityAt DateTime  @default(now())
  convertedAt    DateTime? // When they signed

  // Email cadence state, added Sprint 10
  unsubscribedFromEmails Boolean   @default(false)
  unsubscribedAt         DateTime?
  lastEmailSentAt        DateTime?
  nextScheduledEmailAt   DateTime?
  emailsSent             Int       @default(0)
  cadenceStage           String? // day_one_sent, day_three_sent, ...
  reviewRequestSentAt    DateTime? // When the review request email was sent

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, externalSystem, externalId])
  @@index([orgId, status])
  @@index([orgId, source])
  @@index([email])
  @@index([cadenceStage])
  @@index([propertyId])
}

model Tour {
  id         String   @id @default(cuid())
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  status        TourStatus @default(REQUESTED)
  tourType      String? // in_person, virtual, self_guided
  scheduledAt   DateTime?
  completedAt   DateTime?
  attendeeCount Int?       @default(1)
  notes         String?    @db.Text

  // External system idempotency (e.g. AppFolio Showing Id).
  externalSystem String?
  externalId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([externalSystem, externalId])
  @@index([leadId])
  @@index([propertyId, status])
}

model Application {
  id         String   @id @default(cuid())
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  status    ApplicationStatus @default(STARTED)
  appliedAt DateTime?
  decidedAt DateTime?

  // Denorm of applicant data at time of application
  applicantData Json?

  // External linkage (e.g., AppFolio application ID)
  backendAppId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([propertyId, status])
}

// ============================================================================
// APPFOLIO MIRRORED ENTITIES — Residents, Leases, Work Orders
//
// AppFolio remains the source of truth for everything below. We mirror only
// what we need to surface in the operator dashboard (renewal pipeline,
// vacancy forecasting, property health). Every row carries `externalSystem`
// + `externalId` for idempotent upsert and `raw` JSON for the original
// payload so we can evolve our normalization without re-syncing.
// ============================================================================

enum ResidentStatus {
  ACTIVE
  PAST
  NOTICE_GIVEN
  EVICTED
  APPLICANT
}

model Resident {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  // Optional link to the listing (unit) the resident occupies. Nullable
  // because AppFolio rows occasionally lack the Unit join key.
  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  // Optional bridge to a Lead row when we can match by email.
  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  // Identity
  firstName String?
  lastName  String?
  email     String?
  phone     String?

  status ResidentStatus @default(ACTIVE)

  // Lease summary (denormalized so we can sort by lease end without
  // hopping). Kept in sync with the Lease row.
  currentLeaseId   String?  @unique
  currentLease     Lease?   @relation("CurrentLease", fields: [currentLeaseId], references: [id], onDelete: SetNull)
  unitNumber       String?
  moveInDate       DateTime?
  moveOutDate      DateTime?
  noticeGivenDate  DateTime?
  monthlyRentCents Int?

  externalSystem String? // "appfolio"
  externalId     String? // AppFolio occupancyId / tenantId

  raw Json?

  leases     Lease[]
  workOrders WorkOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, externalSystem, externalId])
  @@index([orgId, status])
  @@index([propertyId, status])
  @@index([email])
  @@index([moveOutDate])
}

enum LeaseStatus {
  PENDING
  ACTIVE
  EXPIRING
  RENEWED
  ENDED
  EVICTED
}

model Lease {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  residentId String?
  resident   Resident? @relation(fields: [residentId], references: [id], onDelete: SetNull)

  status LeaseStatus @default(ACTIVE)

  startDate         DateTime?
  endDate           DateTime?
  monthlyRentCents  Int?
  securityDepositCents Int?
  termMonths        Int?

  // Renewal / decision tracking — driven by AppFolio updates and
  // operator action.
  renewalSentAt    DateTime?
  renewalDecision  String? // "accepted", "declined", "negotiating"
  noticeGivenAt    DateTime?

  // Delinquency snapshot (from delinquency report)
  currentBalanceCents Int? @default(0)
  isPastDue           Boolean @default(false)
  pastDueAsOf         DateTime?

  externalSystem String?
  externalId     String?

  raw Json?

  // Inverse relation back-pointer for Resident.currentLeaseId
  currentForResident Resident? @relation("CurrentLease")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, externalSystem, externalId])
  @@index([orgId, status])
  @@index([propertyId, status])
  @@index([endDate])
  @@index([isPastDue, currentBalanceCents])
}

enum WorkOrderStatus {
  NEW
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  ON_HOLD
}

enum WorkOrderPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model WorkOrder {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  residentId String?
  resident   Resident? @relation(fields: [residentId], references: [id], onDelete: SetNull)

  // The AppFolio work order number ("WO-2024-1138")
  workOrderNumber String?

  status   WorkOrderStatus   @default(NEW)
  priority WorkOrderPriority @default(NORMAL)

  category    String? // "Plumbing", "HVAC", "Appliance", etc.
  title       String?
  description String? @db.Text
  unitNumber  String?

  vendorName  String?
  vendorEmail String?

  reportedAt   DateTime?
  scheduledFor DateTime?
  completedAt  DateTime?

  estimatedCostCents Int?
  actualCostCents    Int?

  externalSystem String?
  externalId     String?

  raw Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, externalSystem, externalId])
  @@index([orgId, status])
  @@index([propertyId, status, priority])
  @@index([reportedAt])
  @@index([completedAt])
}

// ============================================================================
// PIXEL / VISITORS
// ============================================================================

model Visitor {
  id         String       @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  propertyId String?
  property   Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  // Cursive identifier
  cursiveVisitorId String? @unique
  hashedEmail      String? // SHA-256 for ad platform sync
  visitorHash      String? // Unique ID for deduplication

  // Identified data
  status       VisitorIdentificationStatus @default(ANONYMOUS)
  firstName    String?
  lastName     String?
  email        String?
  phone        String?
  enrichedData Json? // Full Cursive enrichment payload

  // Session data
  firstSeenAt      DateTime @default(now())
  lastSeenAt       DateTime @default(now())
  sessionCount     Int      @default(1)
  pagesViewed      Json? // Array of URLs + timestamps
  totalTimeSeconds Int      @default(0)
  referrer         String?
  utmSource        String?
  utmMedium        String?
  utmCampaign      String?

  // Intent score (computed)
  intentScore Int @default(0)

  // Lead conversion
  leads          Lead[]
  convertedAt    DateTime?
  outreachSent   Boolean   @default(false)
  outreachSentAt DateTime?

  // First-party pixel sessions and events
  sessions VisitorSession[]
  events   VisitorEvent[]

  // Operator-initiated chatbot engagements
  chatbotEngagements ChatbotEngagement[]

  // Ad platform sync state
  syncedToGoogleAds Boolean @default(false)
  syncedToMetaAds   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, status])
  @@index([orgId, lastSeenAt])
  @@index([orgId, email])
  @@index([cursiveVisitorId])
  @@index([hashedEmail])
}

model CursiveIntegration {
  id    String       @id @default(cuid())
  orgId String       @unique
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  cursivePixelId    String? // The Cursive pixel ID provisioned for this tenant
  cursiveAccountId  String? // Cursive account this pixel belongs to
  pixelScriptUrl    String? // CDN URL for the pixel script
  installedOnDomain String? // Which hostname the pixel is installed on
  provisionedAt     DateTime?
  lastEventAt       DateTime?
  totalEventsCount  Int       @default(0)

  // Per-tenant webhook token. URL-as-secret so AL's per-pixel webhook UI
  // works without our shared header. 32 hex chars = 128 bits of entropy.
  webhookToken String? @unique

  // AudienceLab segment binding for the admin "Sync from segment" pull
  cursiveSegmentId  String?
  lastSegmentSyncAt DateTime?

  // Weekly digest delivery preferences
  weeklyDigestEnabled Boolean @default(true)
  weeklyDigestEmails  Json? // Array of emails

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// AudienceLab does not expose a programmatic pixel-creation API, so when a
// tenant asks for visitor identification we queue a request here. Ops sets
// up the pixel + segment + workflow in the AL UI, then pastes the resulting
// pixel_id into the admin Cursive panel — which marks the matching request
// FULFILLED and emails the customer with their install snippet.
enum PixelRequestStatus {
  PENDING
  FULFILLED
  CANCELLED
}

model PixelProvisionRequest {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  websiteName String
  websiteUrl  String

  status            PixelRequestStatus @default(PENDING)
  requestedByUserId String?
  requestedAt       DateTime           @default(now())
  fulfilledAt       DateTime?

  // Snapshot of the resulting pixel_id once fulfilled (for audit/debugging).
  fulfilledPixelId String?
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, status])
  @@index([status, requestedAt])
}

// ============================================================================
// FIRST-PARTY PIXEL — sessions + events from our own JS snippet
// ============================================================================
// `Visitor` is the long-lived person record (potentially identified). Each
// browser cookie maps to one or more `VisitorSession`s, and each pageview /
// scroll / time-on-page tick is a `VisitorEvent`. Keeping this in two tables
// stays close to the Segment / PostHog model and keeps Visitor lean.

model VisitorSession {
  id        String       @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  visitorId String?
  visitor   Visitor?     @relation(fields: [visitorId], references: [id], onDelete: SetNull)

  // Cookie / device identifiers (set by our pixel)
  anonymousId  String // cookie value, lives in browser
  sessionToken String  @unique // server-issued per session
  deviceHash   String? // sha256(ua + ip) — helps cross-browser dedupe

  // Acquisition
  firstUrl      String?
  firstReferrer String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  utmTerm       String?
  utmContent    String?

  // Device
  userAgent String?
  ipAddress String?
  country   String?
  language  String?

  // Engagement aggregate (denormalised so the feed page reads in one query)
  pageviewCount    Int @default(0)
  totalTimeSeconds Int @default(0)
  maxScrollDepth   Int @default(0) // 0–100 percentage

  startedAt   DateTime  @default(now())
  lastEventAt DateTime  @default(now())
  endedAt     DateTime?

  events VisitorEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, startedAt])
  @@index([orgId, anonymousId])
  @@index([visitorId])
}

model VisitorEvent {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  sessionId String
  session   VisitorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  visitorId String?
  visitor   Visitor?       @relation(fields: [visitorId], references: [id], onDelete: SetNull)

  type     String // "pageview" | "identify" | "scroll" | "timing" | "click" | "form_submit" | "unload"
  url      String?
  path     String?
  title    String?
  referrer String?

  // Optional payloads (JSON to stay flexible without exploding the schema)
  properties        Json?
  scrollDepth       Int? // 0–100
  timeOnPageSeconds Int?

  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([orgId, occurredAt])
  @@index([sessionId])
  @@index([visitorId])
  @@index([type])
}

// ============================================================================
// CHATBOT
// ============================================================================

model ChatbotConversation {
  id         String       @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  propertyId String?
  property   Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  leadId     String?
  lead       Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)

  status      ChatbotConversationStatus @default(ACTIVE)
  // DECISION: sessionId needs @unique so the chatbot API can upsert on it
  // in one query. Added in Sprint 09.
  sessionId   String                    @unique // Browser session identifier
  visitorHash String? // Link back to Visitor if identified

  // Messages stored as JSON array of {role, content, timestamp}
  messages Json

  // Captured data
  capturedName  String?
  capturedEmail String?
  capturedPhone String?

  // Engagement
  messageCount  Int       @default(0)
  lastMessageAt DateTime  @default(now())
  handedOffAt   DateTime?
  handoffReason String?

  // Metadata
  userAgent String?
  ipAddress String?
  pageUrl   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  flags ConversationFlag[]

  @@index([orgId, status])
  @@index([orgId, lastMessageAt])
  @@index([leadId])
  @@index([propertyId])
  @@index([sessionId])
}

// Operator -> live visitor outbound message. The widget polls
// /api/public/chatbot/inbox for PENDING rows scoped to its sessionId and
// renders them as assistant turns. triggeredById stores the Clerk userId
// (intentionally not a FK so the row outlives operator account deletions).
model ChatbotEngagement {
  id            String           @id @default(cuid())
  orgId         String
  org           Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  visitorId     String?
  visitor       Visitor?         @relation(fields: [visitorId], references: [id], onDelete: SetNull)
  sessionId     String
  triggeredById String
  message       String           @db.Text
  openWidget    Boolean          @default(true)
  status        EngagementStatus @default(PENDING)
  deliveredAt   DateTime?
  repliedAt     DateTime?
  createdAt     DateTime         @default(now())

  @@index([sessionId])
  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@index([visitorId])
}

// ============================================================================
// CREATIVE STUDIO
// ============================================================================

model CreativeRequest {
  id         String       @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  propertyId String?
  property   Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  requestedByUserId String?
  title             String
  description       String         @db.Text
  format            CreativeFormat
  targetDate        DateTime?
  priority          String?        @default("normal")

  // Inputs from client
  referenceImageUrls Json? // Array of uploaded inspiration images
  brandAssetsUrls    Json? // Logos, brand photos they want used
  copyIdeas          String? @db.Text
  targetAudience     String?

  // Fulfillment
  status           CreativeRequestStatus @default(SUBMITTED)
  assignedToUserId String? // Agency team member

  // Conversation (back-and-forth between client and agency)
  messages Json? // Array of {role, from, content, timestamp, attachmentUrls}

  // Deliverables
  deliverableUrls Json? // Array of final asset URLs
  deliveredAt     DateTime?
  approvedAt      DateTime?
  revisionCount   Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, status])
  @@index([status, targetDate])
}

// ============================================================================
// PAID ADS
// ============================================================================

model AdAccount {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  platform          AdPlatform
  externalAccountId String // Google Ads customer ID (10-digit, no dashes); Meta ad account ID (numeric, no act_ prefix)
  displayName       String? // Operator-chosen label, e.g. "Telegraph Commons - Search"
  currency          String?    @default("USD") // ISO 4217. Reported by both APIs.

  accessStatus String? @default("active") // active, expired, revoked, error

  // Encrypted credential bag (stringified JSON). Schema differs per platform:
  //   Google Ads: { developerToken, loginCustomerId?, refreshToken, oauthClientId, oauthClientSecret }
  //   Meta Ads:   { systemUserAccessToken }
  // The integration lib decrypts and parses on use. Keeping it as a single
  // blob lets us avoid a second migration when we add OAuth-issued tokens.
  credentialsEncrypted String? @db.Text

  // Legacy/OAuth fields kept so we can migrate to OAuth later without a
  // schema change. Not used by the V1 paste-in-credentials flow.
  tokenEncrypted        String?   @db.Text
  refreshTokenEncrypted String?   @db.Text
  tokenExpiresAt        DateTime?

  pixelSyncEnabled Boolean   @default(false)
  autoSyncEnabled  Boolean   @default(true)
  lastSyncAt       DateTime?
  lastSyncError    String?   @db.Text

  adCampaigns          AdCampaign[]
  metricsDaily         AdMetricDaily[]
  audienceDestinations AudienceDestination[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, platform, externalAccountId])
  @@index([orgId, platform])
}

model AdCampaign {
  id          String       @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  propertyId  String?
  property    Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  adAccountId String
  adAccount   AdAccount    @relation(fields: [adAccountId], references: [id], onDelete: Cascade)

  externalCampaignId String?
  name               String
  platform           AdPlatform
  status             String? // ENABLED/PAUSED/REMOVED (Google), ACTIVE/PAUSED/DELETED (Meta)
  objective          String? // Meta: OUTCOME_LEADS / OUTCOME_TRAFFIC / ...; Google: SEARCH/PMAX/DISPLAY/...

  // Budget
  dailyBudgetCents   Int?
  monthlyBudgetCents Int?
  spendToDateCents   Int?      @default(0)
  startDate          DateTime?
  endDate            DateTime?

  // Performance (denormalized, refreshed via cron from AdMetricDaily)
  impressions Int?      @default(0)
  clicks      Int?      @default(0)
  conversions Int?      @default(0)
  lastStatsAt DateTime?

  startedAt DateTime?
  endedAt   DateTime?

  metricsDaily AdMetricDaily[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([adAccountId, externalCampaignId])
  @@index([orgId, status])
  @@index([adAccountId])
}

// Per-campaign per-day metrics. One row per (campaignId, date) so the cron
// can upsert idempotently. The dashboard reads this for time-series + 28-day
// aggregates; AdCampaign holds the rolling totals as a denorm.
model AdMetricDaily {
  id          String     @id @default(cuid())
  orgId       String
  adAccountId String
  adAccount   AdAccount  @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  campaignId  String
  campaign    AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  date                   DateTime @db.Date // UTC midnight of the metric day
  impressions            Int      @default(0)
  clicks                 Int      @default(0)
  spendCents             Int      @default(0)
  conversions            Float    @default(0) // Meta returns fractional conversions
  conversionValueCents   Int      @default(0)
  ctr                    Float    @default(0) // clicks / impressions, 0..1
  cpcCents               Int      @default(0) // spend / clicks
  costPerConversionCents Int      @default(0) // spend / conversions

  raw Json? // Raw payload from the platform for debugging

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([campaignId, date])
  @@index([orgId, date])
  @@index([adAccountId, date])
}

// ============================================================================
// BACKEND INTEGRATIONS
// ============================================================================

model AppFolioIntegration {
  id    String       @id @default(cuid())
  orgId String       @unique
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  instanceSubdomain     String // e.g., sgrealestate (from sgrealestate.appfolio.com)
  plan                  String? // "plus", "max", "core"
  apiKeyEncrypted       String?   @db.Text
  clientIdEncrypted     String?   @db.Text
  clientSecretEncrypted String?   @db.Text
  oauthTokenEncrypted   String?   @db.Text
  oauthRefreshEncrypted String?   @db.Text
  oauthExpiresAt        DateTime?

  // Sync state
  lastSyncAt DateTime?
  // When the current "syncing" run actually started. Persisted so the UI
  // can show real elapsed time across page navigations (a per-component
  // local counter resets on every mount and reads as a "sync restart"
  // even when the underlying sync is still running). Cleared on
  // completion. Used by the status helper to mark stuck syncs (older
  // than 10 min) as failed instead of letting them sit forever.
  syncStartedAt DateTime?
  syncStatus    String? // idle, syncing, error
  lastError     String?
  // Detailed stats from the most recent sync run. Persisted so the UI can
  // surface "X residents · Y leases · Z work orders pulled" + per-phase
  // warnings even when the sync technically succeeded but a sub-endpoint
  // (e.g. residents) silently returned 0 rows or 403'd. Shape matches
  // AppfolioSyncStats in lib/integrations/appfolio-sync.ts.
  lastSyncStats Json?

  // Configuration
  propertyGroupFilter  String? // Only sync specific property groups
  syncFrequencyMinutes Int     @default(60)
  autoSyncEnabled      Boolean @default(true)

  // Fallback mode
  useEmbedFallback  Boolean @default(false)
  embedScriptConfig Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================================
// KEPT FROM WHOLESAIL (SURVIVE AS-IS OR LIGHTLY EXTENDED)
// ============================================================================

model Address {
  id         String       @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  label      String?
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String       @default("US")
  isDefault  Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([orgId])
}

model AuditEvent {
  id     String       @id @default(cuid())
  orgId  String
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId String?
  user   User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  action      AuditAction
  entityType  String // "Lead", "Property", etc.
  entityId    String?
  description String?
  diff        Json?
  ipAddress   String?
  userAgent   String?

  createdAt DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([entityType, entityId])
}

model WebhookEvent {
  id               String   @id @default(cuid())
  source           String // "cursive", "appfolio", "stripe"
  bodyHash         String? // SHA-256 of raw POST body, hex. Catches byte-identical AL retries.
  eventFingerprint String? // sha256(pixel_id|profile_id|event_timestamp|event_type). Catches re-serialized duplicates within a batch.
  eventType        String?
  orgId            String?
  receivedAt       DateTime @default(now())

  // Retry queue tracking — webhook-retry cron picks up status=failed events
  // whose nextRetryAt is in the past.
  status          String    @default("received") // received | processed | failed | abandoned
  attempts        Int       @default(0)
  lastAttemptAt   DateTime?
  processingError String?   @db.Text
  rawBody         String?   @db.Text // Stored only when processing fails so retries can replay
  nextRetryAt     DateTime?

  @@unique([source, bodyHash])
  @@unique([source, eventFingerprint])
  @@index([source, receivedAt])
  @@index([status, nextRetryAt])
}

// Per-tenant request to activate an integration that isn't self-serve yet.
// The portal marketplace drawer writes one of these when the operator clicks
// "Request activation" on a tile whose auth flow isn't built yet. Surfaces
// in the admin queue so we know what to prioritize building.
model IntegrationRequest {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  integrationSlug  String // matches lib/integrations/catalog.ts slug
  status           IntegrationRequestStatus @default(PENDING)
  message          String?                  @db.Text
  requestedByEmail String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  @@index([orgId, status])
  @@index([integrationSlug, status])
}

enum IntegrationRequestStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  REJECTED
}

// ============================================================================
// SEO MODULE
// ----------------------------------------------------------------------------
// Pulls organic search performance data from two providers per tenant:
//   - GSC  → Google Search Console (queries, impressions, clicks, position)
//   - GA4  → Google Analytics Data API (organic sessions, users, engagement,
//            top landing pages)
//
// Both authenticate via a service account JSON pasted by the operator. The
// service account email must be granted access to the GSC site / GA4 property
// before connecting. JSON is encrypted at rest using lib/crypto.ts.
//
// Snapshots are written daily by /api/cron/seo-sync. Schema is normalized so
// trends across weeks/months can be queried cheaply with date range filters.
// ============================================================================

enum SeoProvider {
  GSC
  GA4
}

enum SeoSyncStatus {
  IDLE
  SYNCING
  ERROR
}

model SeoIntegration {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  provider                    SeoProvider
  // GSC: full site URL, e.g. "sc-domain:telegraphcommons.com" or
  //      "https://www.telegraphcommons.com/". GA4: property id, e.g. "123456789".
  propertyIdentifier          String
  serviceAccountEmail         String? // surfaced in UI so operators know which email to grant access to
  serviceAccountJsonEncrypted String      @db.Text // encrypted full JSON payload

  status        SeoSyncStatus @default(IDLE)
  lastSyncAt    DateTime?
  lastSyncError String?       @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, provider])
  @@index([orgId])
}

// Daily aggregate per tenant. Re-run-safe via the unique (orgId, date) index.
model SeoSnapshot {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  date             DateTime // start of the calendar day in UTC
  organicSessions  Int      @default(0)
  organicUsers     Int      @default(0)
  totalImpressions Int      @default(0)
  totalClicks      Int      @default(0)
  avgCtr           Float    @default(0) // 0 to 1
  avgPosition      Float    @default(0) // GSC search position, lower is better

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, date])
  @@index([orgId, date])
}

// One row per (tenant, date, query). Drives the "top queries" table.
model SeoQuery {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  date        DateTime
  query       String   @db.Text
  impressions Int      @default(0)
  clicks      Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)

  createdAt DateTime @default(now())

  @@unique([orgId, date, query])
  @@index([orgId, date])
  @@index([orgId, clicks])
}

// One row per (tenant, date, url). Drives the "top landing pages" table.
model SeoLandingPage {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  date              DateTime
  url               String   @db.Text
  sessions          Int      @default(0)
  users             Int      @default(0)
  bounceRate        Float    @default(0)
  avgEngagementTime Float    @default(0) // seconds

  createdAt DateTime @default(now())

  @@unique([orgId, date, url])
  @@index([orgId, date])
  @@index([orgId, sessions])
}

model ClientNote {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  authorUserId String?
  noteType     NoteType @default(GENERAL)
  body         String   @db.Text
  pinned       Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, createdAt])
}

model IntakeSubmission {
  id    String        @id @default(cuid())
  orgId String?       @unique // Null until org created
  org   Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  // Step 1: Company
  companyName         String
  shortName           String?
  websiteUrl          String?
  propertyType        PropertyType
  residentialSubtype  ResidentialSubtype?
  commercialSubtype   CommercialSubtype?
  primaryContactName  String
  primaryContactEmail String
  primaryContactPhone String?
  primaryContactRole  String?
  hqCity              String?
  hqState             String?

  // Step 2: Portfolio
  numberOfProperties       Int?
  currentBackendPlatform   BackendPlatform @default(NONE)
  backendPlanTier          String?
  currentVendor            String?
  currentMonthlySpendCents Int?
  biggestPainPoint         String?

  // Step 3: Service selection (module toggles)
  selectedModules Json // Array of module keys

  // Step 4: Timeline + consultation
  goLiveTarget String? // asap, 1_month, 3_month, exploring
  bookedCallAt DateTime?
  calBookingId String?

  // Submission metadata
  status      String    @default("submitted") // submitted, in_review, converted, rejected
  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?
  convertedAt DateTime?

  ipAddress   String?
  userAgent   String?
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  raw Json? // Full form payload for audit
}

model Project {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  name        String // e.g., "Telegraph Commons Build"
  description String?
  status      String  @default("active") // active, on_hold, completed, cancelled

  startedAt          DateTime?
  targetCompletionAt DateTime?
  completedAt        DateTime?

  tasks ProjectTask[]
  costs ProjectCost[]
  notes ProjectNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId, status])
}

model ProjectTask {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title            String
  description      String?
  status           TaskStatus @default(TODO)
  assignedToUserId String?
  assignedTo       User?      @relation("TaskAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  phase       String? // "Build", "QA", "Launch", etc.
  sortOrder   Int       @default(0)
  dueAt       DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, status])
}

model ProjectCost {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  label       String
  amountCents Int
  category    String? // infrastructure, api_cost, ad_spend, etc.
  incurredAt  DateTime @default(now())

  createdAt DateTime @default(now())

  @@index([projectId])
}

model ProjectNote {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  authorUserId String?
  body         String  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model EmailSubscriber {
  id    String        @id @default(cuid())
  orgId String? // Null = platform-level subscriber
  org   Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  email     String
  firstName String?
  source    String? // lead_magnet, footer, blog, etc.
  tags      Json?

  confirmed      Boolean   @default(false)
  confirmedAt    DateTime?
  unsubscribed   Boolean   @default(false)
  unsubscribedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, email])
  @@index([orgId])
}

// ============================================================================
// SYSTEM HEALTH
// ----------------------------------------------------------------------------
// One row per cron handler invocation. Written by lib/health/cron-run.ts at
// start (status=running) and updated on finish (ok/error/timeout). The
// /admin/system dashboard reads the most recent row per jobName so an
// operator can see at a glance which crons fired in the last 24 hours and
// which are silently dead. Migration lives in
// prisma/migrations_pending/2026-04-20-cron-runs.sql (Adam applies).
// ============================================================================

model CronRun {
  id               String    @id @default(cuid())
  jobName          String
  startedAt        DateTime  @default(now())
  finishedAt       DateTime?
  status           String    @default("running") // running | ok | error | timeout
  error            String?   @db.Text
  durationMs       Int?
  recordsProcessed Int?

  createdAt DateTime @default(now())

  @@index([jobName, startedAt])
  @@index([startedAt])
  @@index([status])
}

// ============================================================================
// NOTIFICATIONS
// ----------------------------------------------------------------------------
// In-app notification inbox for operators. Rows are created by server helpers
// when interesting events occur (new lead, tour scheduled, chatbot lead, etc.).
// The portal header bell polls /api/portal/notifications/unread-count every
// 30 s and the /portal/notifications page lists all rows for the org.
// ============================================================================

model Notification {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Optional: target a specific user. Null = org-wide (visible to all members).
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Event classification
  kind String // lead_created | tour_scheduled | chatbot_lead | integration_error | sync_complete

  // Display
  title String
  body  String? @db.Text

  // Optional link back to the source entity
  entityType String?
  entityId   String?
  href       String? // /portal/leads/<id> etc.

  // Read state
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([orgId, readAt])
  @@index([orgId, createdAt(sort: Desc)])
  @@index([orgId, kind])
}

// ============================================================================
// INSIGHTS
// ----------------------------------------------------------------------------
// Proactively detected anomalies and opportunities. A background cron
// (insight-detector) runs scheduled checks per org and upserts Insight rows
// via dedupeKey so the same anomaly doesn't fire repeatedly. Operators view
// them on /portal/insights and in the Command Center briefing.
// ============================================================================

model Insight {
  id         String       @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  propertyId String?
  property   Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  // Classification
  kind     String // traffic_drop | traffic_spike | pipeline_stall | chatbot_pattern | cpl_spike | keyword_drop | conv_rate_drop | hot_visitor
  severity String @default("info") // info | warning | critical
  category String // traffic | leads | ads | seo | chatbot | occupancy

  title           String
  body            String  @db.Text
  suggestedAction String? @db.Text

  // Optional link back to the source entity
  entityType String? // lead | property | campaign | conversation | visitor
  entityId   String?
  href       String? // /portal/... deep link

  // Metric context for rendering (JSON):
  // { before, after, deltaPct, periodStart, periodEnd, sampleSize, ... }
  context Json?

  // Operator workflow
  status         String    @default("open") // open | acknowledged | dismissed | acted
  acknowledgedAt DateTime?
  acknowledgedBy String? // userId
  dismissedAt    DateTime?
  snoozeUntil    DateTime?

  // Dedupe so the same anomaly doesn't fire repeatedly. Detectors compose
  // stable keys like "traffic_drop:propertyId:week:2026-16".
  dedupeKey String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, dedupeKey])
  @@index([orgId, status, severity])
  @@index([orgId, createdAt(sort: Desc)])
  @@index([orgId, category, status])
  @@index([propertyId])
}

// ============================================================================
// CLIENT REPORTS
// ----------------------------------------------------------------------------
// Operator-generated weekly and monthly client reports. snapshot is frozen at
// generation time so viewing the report later shows the exact numbers the
// operator sent. shareToken powers /r/[token] public viewer. Operator writes
// a personal note (headline + notes) before sharing.
// ============================================================================

model ClientReport {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Optional property scope. When set, the snapshot's queries were filtered
  // to this property only — useful for multi-property tenants who want a
  // per-asset client report instead of a portfolio-wide rollup. NULL means
  // org-wide (the original behavior). SetNull on delete so historical
  // reports survive a property removal with the scope context dropped.
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  kind        String // weekly | monthly | custom
  periodStart DateTime
  periodEnd   DateTime

  // Frozen data snapshot used for rendering the report.
  // Shape: { kpis, funnel, leadSources, topProperties, insights, trafficTrend, ... }
  snapshot Json

  // Operator additions shown at top of report
  headline String?
  notes    String? @db.Text

  // Sharing
  shareToken   String    @unique // short URL token for /r/[token]
  sharedAt     DateTime?
  lastViewedAt DateTime?
  viewCount    Int       @default(0)

  status String @default("draft") // draft | shared | archived

  generatedAt DateTime @default(now())
  generatedBy String? // userId (no FK — rows outlive user deletes)
  updatedAt   DateTime @updatedAt

  @@index([orgId, kind, periodStart(sort: Desc)])
  @@index([orgId, status, generatedAt(sort: Desc)])
  @@index([orgId, propertyId, generatedAt(sort: Desc)])
  @@index([shareToken])
}

// ============================================================================
// CONVERSATION FLAGS
// ----------------------------------------------------------------------------
// Operator annotations on chatbot conversations. Used in the transcript review
// tool to mark quality, flag for prompt tuning, rate lead quality, add notes.
// Multiple flags per conversation are allowed (e.g. "good quality" + "needs
// followup" + "high-intent lead").
// ============================================================================

model ConversationFlag {
  id             String              @id @default(cuid())
  conversationId String
  conversation   ChatbotConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  orgId          String
  org            Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Flag type
  flag String // quality_good | quality_bad | needs_prompt_tuning | lead_high_intent | lead_low_intent | followup_needed | handoff_missed
  note String? @db.Text

  createdByUserId String?
  createdAt       DateTime @default(now())

  @@index([orgId, flag])
  @@index([conversationId])
  @@index([orgId, createdAt(sort: Desc)])
}

// ============================================================================
// REPUTATION SCANNER
// ----------------------------------------------------------------------------
// On-demand reputation & intent-signal scanner. A customer clicks "Scan Now"
// on a Property; the API route fans out to Google Places, Tavily, Reddit, and
// Yelp, dedupes by URL hash, classifies sentiment/topics via Claude Haiku,
// and persists results here. ReputationScan captures the run metadata;
// PropertyMention captures each individual mention (one row per unique
// URL per property per org).
// ============================================================================

enum ReputationScanStatus {
  RUNNING
  SUCCEEDED
  PARTIAL // at least one source failed but others returned data
  FAILED
}

enum MentionSource {
  GOOGLE_REVIEW
  REDDIT
  YELP
  TAVILY_WEB
  FACEBOOK_PUBLIC
  OTHER
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
  MIXED
}

model ReputationScan {
  id         String       @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  triggeredByUserId String? // internal User.id, not Clerk id
  status            ReputationScanStatus @default(RUNNING)

  // Per-source result summary: { google: { found, newCount, ok, error? }, ... }
  sources Json?

  newMentionCount   Int     @default(0)
  totalMentionCount Int     @default(0)
  estCostCents      Int     @default(0)
  durationMs        Int?
  error             String?

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  mentions PropertyMention[]

  @@index([orgId, propertyId, createdAt(sort: Desc)])
  @@index([orgId, status])
}

model PropertyMention {
  id         String       @id @default(cuid())
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  source    MentionSource
  sourceUrl String // canonical URL
  urlHash   String // sha256 of normalized URL, used for dedupe

  title       String?
  excerpt     String    @db.Text
  authorName  String?
  publishedAt DateTime?
  rating      Float? // 1-5 when available (Google, Yelp)

  sentiment Sentiment?
  topics    Json? // Array of strings, e.g. ["maintenance", "noise"]

  reviewedByUserId String?
  flagged          Boolean @default(false)

  firstSeenScanId String
  firstSeenScan   ReputationScan @relation(fields: [firstSeenScanId], references: [id], onDelete: Cascade)
  lastSeenAt      DateTime       @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, propertyId, urlHash])
  @@index([orgId, propertyId, publishedAt(sort: Desc)])
  @@index([orgId, propertyId, sentiment])
  @@index([firstSeenScanId])
}

// ============================================================================
// AUDIENCE SYNC — residential/commercial product line
// ============================================================================
// AudienceSegment caches AudienceLab segments visible to an org. Cache is
// refreshed on dashboard load or via a manual "Refresh" action. We don't
// persist members here; members are fetched on-demand at push time.

enum AudienceDestinationType {
  CSV_DOWNLOAD
  WEBHOOK
  META_CUSTOM_AUDIENCE
  GOOGLE_CUSTOMER_MATCH
}

enum AudienceSyncStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model AudienceSegment {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // AudienceLab segment id (their primary key, opaque string)
  alSegmentId String
  name        String
  description String?

  // Last known member count from AL. Refreshed on list pulls.
  memberCount Int @default(0)

  // Stash the raw AL payload for the segment so we can render attribute
  // chips without a second round-trip. Updated on every refresh.
  rawPayload Json?

  // Whether this org chooses to surface the segment in their dashboard.
  // Defaults to true on import; toggled off if user hides it.
  visible Boolean @default(true)

  lastFetchedAt DateTime?

  destinations AudienceDestination[]
  syncRuns     AudienceSyncRun[]
  schedules    AudienceSyncSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, alSegmentId])
  @@index([orgId, visible])
}

model AudienceDestination {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  type AudienceDestinationType
  name String // operator-friendly label

  // For WEBHOOK: target URL + signing secret. Stored encrypted (AES-GCM)
  // via the same maybeDecrypt helper used for ad creds.
  webhookUrl       String?
  webhookSecretEnc String?

  // For META_CUSTOM_AUDIENCE / GOOGLE_CUSTOMER_MATCH: pointer to the
  // already-connected AdAccount. Reuses existing OAuth credentials.
  adAccountId String?
  adAccount   AdAccount? @relation(fields: [adAccountId], references: [id], onDelete: SetNull)

  // External audience id on the destination platform (Meta CA id, Google
  // user list resource name). Created lazily on first push.
  externalAudienceId String?

  // Optional segment binding. When set, this destination is "default" for
  // the segment and shows on its detail page. Null means "shared/global"
  // across all segments in the org.
  segmentId String?
  segment   AudienceSegment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)

  enabled    Boolean   @default(true)
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  syncRuns  AudienceSyncRun[]
  schedules AudienceSyncSchedule[]

  @@index([orgId, type])
  @@index([segmentId])
  @@index([adAccountId])
}

model AudienceSyncRun {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  segmentId     String
  segment       AudienceSegment     @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  destinationId String
  destination   AudienceDestination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  status      AudienceSyncStatus @default(PENDING)
  memberCount Int                @default(0)

  // Geo filter snapshot at run time (zip codes, state, radius). Null if
  // no filter was applied.
  filterSnapshot Json?

  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  errorMessage String?

  // Triggered by user (userId) or system cron (null).
  triggeredByUserId String?

  @@index([orgId, startedAt(sort: Desc)])
  @@index([segmentId, startedAt(sort: Desc)])
  @@index([destinationId, startedAt(sort: Desc)])
  @@index([status])
}

// AudienceSyncSchedule defines a recurring push of a segment to a destination.
// The cron at /api/cron/run-audience-syncs picks rows where enabled=true and
// nextRunAt <= now() each tick, executes the push, then advances nextRunAt to
// the next due time based on frequency.
enum AudienceScheduleFrequency {
  DAILY
  WEEKLY
}

model AudienceSyncSchedule {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  segmentId     String
  segment       AudienceSegment     @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  destinationId String
  destination   AudienceDestination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  frequency AudienceScheduleFrequency
  // 0-6 (Sunday=0). Required when frequency = WEEKLY, ignored when DAILY.
  dayOfWeek Int?
  // 0-23, the hour of the day (UTC) the run kicks off.
  hourUtc   Int

  // Optional GeoFilter snapshot { zipCodes?: string[]; states?: string[]; cities?: string[] }
  filterSnapshot Json?

  enabled    Boolean   @default(true)
  lastRunAt  DateTime?
  nextRunAt  DateTime

  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([orgId, enabled])
  @@index([nextRunAt, enabled])
  @@index([segmentId])
  @@index([destinationId])
}

// ============================================================================
// AD LIBRARY TRACKING
// ============================================================================
//
// Snapshots of public ads found in Meta's Ad Library for any advertiser the
// operator wants to track. Pulled via the public Ad Library API at
// graph.facebook.com/v19.0/ads_archive (requires a Meta app access token,
// not customer credentials — agency holds one app token). Refreshed daily
// by cron; diffs against prior snapshots so the operator sees "3 ads
// launched this week, 1 went inactive".
//
// Importantly: Meta only exposes impressions/spend RANGES for political /
// issue / social ads. Commercial ads return creative + status + dates only.
// We surface what's available; the schema is permissive.

model AdLibraryAdvertiser {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Optional property scope — when set, the widget renders on the
  // property detail page; when null, it's an org-wide tracker.
  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  // What we feed Meta's Ad Library search. Either a Page ID or a search
  // term (the operator can paste either).
  searchKind  AdLibrarySearchKind
  searchValue String

  // Friendly label displayed in the UI (e.g. "Telegraph Commons").
  displayName String

  lastScannedAt DateTime?
  lastScanError String?

  ads AdLibraryAd[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, searchValue])
  @@index([orgId])
  @@index([propertyId])
}

enum AdLibrarySearchKind {
  PAGE_ID
  SEARCH_TERM
}

model AdLibraryAd {
  id           String              @id @default(cuid())
  advertiserId String
  advertiser   AdLibraryAdvertiser @relation(fields: [advertiserId], references: [id], onDelete: Cascade)

  // Meta's library ID for this ad. Unique per advertiser.
  externalId String

  // Status from Meta — ACTIVE / INACTIVE.
  status String

  // Creative content (any field may be null depending on ad type).
  creativeBody  String? @db.Text
  creativeTitle String? @db.Text
  ctaText       String?
  imageUrl      String? @db.Text
  videoUrl      String? @db.Text
  linkUrl       String? @db.Text

  // Reach + spend RANGES — only populated for political/issue ads.
  impressionsLow  Int?
  impressionsHigh Int?
  spendLow        Int? // cents
  spendHigh       Int? // cents
  currency        String?

  // Publisher platforms the ad runs on (FACEBOOK, INSTAGRAM, AUDIENCE_NETWORK, MESSENGER).
  publisherPlatforms String[]

  // Lifecycle dates.
  adCreationTime  DateTime?
  adDeliveryStart DateTime?
  adDeliveryStop  DateTime?

  // Raw payload for forward-compat — Meta adds fields without notice.
  raw Json?

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  @@unique([advertiserId, externalId])
  @@index([advertiserId, status])
}
